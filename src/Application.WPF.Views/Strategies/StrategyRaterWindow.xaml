<Window x:Class="Application.WPF.Views.Strategies.StrategyRaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
        xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="700" SizeToContent="Height"
        MaxHeight="800"
        KeyDown="OnKeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />

        <Style x:Key="RatingChip" TargetType="ListBoxItem">
            <Setter Property="Width"                      Value="32" />
            <Setter Property="Height"                     Value="32" />
            <Setter Property="Margin"                     Value="3,0" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment"   Value="Center" />
            <Setter Property="Foreground"                 Value="#666688" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" CornerRadius="16"
                                Background="Transparent"
                                BorderBrush="#333355" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"  Value="#1A00D4FF" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#00D4FF" />
                                <Setter Property="Foreground"                  Value="#00D4FF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background"  Value="#00D4FF" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#00D4FF" />
                                <Setter Property="Foreground"                  Value="#0A0E1A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#BB000000">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
              Width="660" Margin="20">
            <Border Background="#0F1117" BorderBrush="#00D4FF"
                    BorderThickness="1" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40"
                                      ShadowDepth="0" Opacity="0.9" />
                </Border.Effect>
                <StackPanel>

                    <!-- ── Encabezado ── -->
                    <Border Background="#161B27" CornerRadius="12,12,0,0" Padding="24,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Width="3" Height="18" CornerRadius="1.5"
                                            Background="#00D4FF" Margin="0,0,10,0"
                                            VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Tr Strategy_RaterTitle}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#00D4FF"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding StrategyTitle}"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="White"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Badge promedio + indicador calidad -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                        Margin="16,0,0,0"
                                        Visibility="{Binding HasRatings, Converter={StaticResource BoolToVisibility}}">
                                <Border CornerRadius="8" Padding="16,10" BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#00D4FF" Opacity="0.08" />
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#00D4FF" Opacity="0.35" />
                                    </Border.BorderBrush>
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr Strategy_RaterAvgLabel}" FontSize="9" FontWeight="Bold"
                                                   Foreground="#888888" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding AverageRatingDisplay}"
                                                   FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF5555" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsQualified}" Value="True">
                                                            <Setter Property="Foreground" Value="#00E676" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding QualityLabel}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF5555" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsQualified}" Value="True">
                                                            <Setter Property="Foreground" Value="#00E676" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{loc:Tr Strategy_RaterThreshold}"
                                           FontSize="9" Foreground="#444466"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Mensajes ── -->
                    <StackPanel Margin="24,10,24,0">
                        <Border Background="#1A00E676" BorderBrush="#00E676" BorderThickness="1"
                                CornerRadius="6" Padding="12,8"
                                Visibility="{Binding GeneralSuccess, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding GeneralSuccess}" FontSize="12"
                                       Foreground="#00E676" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="#1AFF4444" BorderBrush="#FF5555" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,4,0,0"
                                Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding GeneralError}" FontSize="12"
                                       Foreground="#FF5555" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!-- Sin confluencias configuradas -->
                    <Border Margin="24,16,24,8" Padding="20,16" CornerRadius="8"
                            Background="#161B27"
                            Visibility="{Binding HasNoConfluences, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Tr Strategy_NoConfluences}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFB300"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{loc:Tr Strategy_NoConfluencesHint}"
                                       FontSize="12" Foreground="#666688"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ── Lista de confluencias ── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="490"
                                  Margin="0,12,0,0" Padding="24,0,24,4">
                        <ItemsControl ItemsSource="{Binding Confluences}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#161B27" CornerRadius="8"
                                            Margin="0,0,0,8" Padding="16,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="26" Height="26" CornerRadius="13"
                                                        BorderBrush="#00D4FF" BorderThickness="1"
                                                        Margin="0,0,12,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#00D4FF" Opacity="0.1" />
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding DisplayIndex}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="#00D4FF"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Description}"
                                                           FontSize="13" Foreground="White"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />

                                                <Border Grid.Column="2" CornerRadius="4"
                                                        Padding="8,3" Margin="10,0,0,0"
                                                        Visibility="{Binding IsRated, Converter={StaticResource BoolToVisibility}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#00D4FF" Opacity="0.12" />
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding RatingDisplay}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="#00D4FF" />
                                                </Border>
                                            </Grid>

                                            <Rectangle Grid.Row="1" Height="1" Fill="#1E2233"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <TextBlock Text="{loc:Tr Strategy_RaterRatingLabel}"
                                                           FontSize="11" Foreground="#666688"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0" />
                                                <ListBox ItemsSource="{Binding RelativeSource=
                                                         {RelativeSource AncestorType=Window},
                                                         Path=DataContext.RatingValues}"
                                                         SelectedValue="{Binding Rating, Mode=TwoWay}"
                                                         ItemContainerStyle="{StaticResource RatingChip}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Tag="{Binding}"
                                                         PreviewMouseLeftButtonDown="OnRatingClick">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="{Binding RelativeSource=
                                                                       {RelativeSource AncestorType=ListBoxItem},
                                                                       Path=Foreground}" />
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- ── Pie ── -->
                    <Border Background="#161B27" CornerRadius="0,0,12,12" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{loc:Tr Strategy_RaterHint}"
                                       FontSize="10" Foreground="#444466"
                                       VerticalAlignment="Center" TextWrapping="Wrap" />

                            <Button Grid.Column="1" Command="{Binding CancelCommand}"
                                    Content="{loc:Tr Strategy_Cancel}" Width="100" Height="36"
                                    Margin="0,0,10,0" Foreground="#AAAAAA"
                                    Background="Transparent" BorderBrush="#333355"
                                    BorderThickness="1" FontSize="13" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="6"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#15FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{Binding SaveCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                    Width="130" Height="36"
                                    FontSize="13" FontWeight="SemiBold"
                                    Foreground="#0A0E1A" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="{loc:Tr Strategy_RaterSave}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" CornerRadius="6">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#00D4FF" Offset="0" />
                                                                <GradientStop Color="#0088AA" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Opacity" Value="0.85" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bg" Property="Opacity" Value="0.4" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Content" Value="{loc:Tr Strategy_RaterSaving}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
