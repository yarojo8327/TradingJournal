<UserControl x:Class="Application.WPF.Views.Strategies.TradingStrategyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Strategies;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TradingStrategyViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
        <converters:ByteArrayToImageConverter   x:Key="BytesToImage" />
        <converters:IntToVisibilityConverter    x:Key="IntToVisibility" />

        <!-- Botón de acción en tarjeta -->
        <Style x:Key="CardActionButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Padding"         Value="8,4" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#15FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón eliminar regla -->
        <Style x:Key="RemoveRuleButton" TargetType="Button" BasedOn="{StaticResource CardActionButton}">
            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
            <Setter Property="Padding"    Value="6,2" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="40,32,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="520" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════
                 COLUMNA IZQUIERDA — Lista de estrategias
                 ══════════════════════════════════════ -->
            <StackPanel Grid.Column="0">

                <!-- Encabezado -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="3" Height="22" CornerRadius="1.5"
                                    Background="{DynamicResource CyanGlowBrush}"
                                    Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="Estrategias"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Metodologías y sistemas de trading"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="13,0,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Bottom"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding NewStrategyCommand}"
                            Height="34" Padding="14,0" FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="15" FontWeight="Bold"
                                       Margin="0,0,5,0" VerticalAlignment="Center" />
                            <TextBlock Text="Nueva" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Mensajes -->
                <Border Background="#1A00E676" BorderBrush="#00E676" BorderThickness="1"
                        CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                        Visibility="{Binding GeneralSuccess, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralSuccess}" FontSize="12"
                               Foreground="#00E676" TextWrapping="Wrap" />
                </Border>
                <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                        Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralError}" FontSize="12"
                               Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                </Border>

                <!-- Estado vacío -->
                <Border Style="{DynamicResource Card}" Padding="24,32"
                        Visibility="{Binding HasNoStrategies, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📈" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12" />
                        <TextBlock Text="Sin estrategias registradas"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Crea tu primera estrategia de trading"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Tarjetas de estrategias -->
                <ItemsControl ItemsSource="{Binding Strategies}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{DynamicResource Card}" Margin="0,0,0,12" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Fila 1: Imagen + Título + Botones -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Miniatura de imagen (solo si HasImage) -->
                                        <Border Grid.Column="0" Width="48" Height="48"
                                                CornerRadius="6" ClipToBounds="True"
                                                Background="{DynamicResource SurfaceElevatedBrush}"
                                                Margin="0,0,12,0"
                                                Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                                            <Image Source="{Binding ImageData, Converter={StaticResource BytesToImage}}"
                                                   Stretch="UniformToFill" />
                                        </Border>

                                        <!-- Ícono cuando no hay imagen -->
                                        <Border Grid.Column="0" Width="48" Height="48"
                                                CornerRadius="6"
                                                Background="{DynamicResource SurfaceElevatedBrush}"
                                                Margin="0,0,12,0"
                                                Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility},
                                                             ConverterParameter=inverse}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="📊" FontSize="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Título -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding Rules.Count, StringFormat={}{0}}" />
                                                <Run Text=" regla(s)" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Botones -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource CardActionButton}"
                                                    Foreground="{DynamicResource CyanGlowBrush}"
                                                    Command="{Binding DataContext.EditStrategyCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,4,0">
                                                <TextBlock Text="✏ Editar" FontSize="11" />
                                            </Button>
                                            <Button Style="{StaticResource CardActionButton}"
                                                    Foreground="{DynamicResource AccentRedBrush}"
                                                    Command="{Binding DataContext.DeleteStrategyCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="🗑 Eliminar" FontSize="11" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Descripción -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibility}}" />

                                    <!-- Separador -->
                                    <Rectangle Grid.Row="2" Height="1"
                                               Fill="{DynamicResource BorderBrush}"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding Rules.Count, Converter={StaticResource IntToVisibility}}" />

                                    <!-- Primeras 2 reglas como preview -->
                                    <ItemsControl Grid.Row="3"
                                                  ItemsSource="{Binding Rules}"
                                                  Visibility="{Binding Rules.Count, Converter={StaticResource IntToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <Ellipse Width="5" Height="5"
                                                             Fill="{DynamicResource CyanGlowBrush}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,7,0" />
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

            <!-- ══════════════════════════════════════
                 COLUMNA DERECHA — Formulario
                 ══════════════════════════════════════ -->
            <StackPanel Grid.Column="2"
                        Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}">

                <!-- Encabezado del formulario -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Height="20" CornerRadius="1.5"
                                Background="{DynamicResource PrimaryBrush}"
                                Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕ Cancelar"
                            Style="{DynamicResource GhostButton}"
                            Command="{Binding CancelCommand}"
                            FontSize="11" Padding="10,5" />
                </Grid>

                <!-- ── Datos generales ── -->
                <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Datos generales"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource CyanGlowBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Título -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Título *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="Ej: Ruptura de rangos, Tendencia en H4…" />
                            <ItemsControl ItemsSource="{Binding (Validation.Errors),
                                          RelativeSource={RelativeSource AncestorType=TextBox}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ErrorContent}" FontSize="11"
                                                   Foreground="{DynamicResource AccentRedBrush}"
                                                   Margin="2,3,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Descripción -->
                        <StackPanel>
                            <TextBlock Text="Descripción"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="Describe brevemente la estrategia…"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="72"
                                     VerticalContentAlignment="Top" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Imagen ── -->
                <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Imagen de referencia (opcional)"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource CyanGlowBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Preview de imagen -->
                        <Border CornerRadius="8" ClipToBounds="True"
                                MaxHeight="180" Margin="0,0,0,12"
                                Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                            <Image Source="{Binding ImagePreview}"
                                   Stretch="Uniform" />
                        </Border>

                        <!-- Zona de drop / placeholder sin imagen -->
                        <Border CornerRadius="8" BorderThickness="1.5"
                                Height="80" Margin="0,0,0,12"
                                Visibility="{Binding HasImage, Converter={StaticResource InverseBool},
                                             ConverterParameter=visibility}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                    <Setter Property="Background"  Value="{DynamicResource SurfaceElevatedBrush}" />
                                    <Setter Property="Visibility"  Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🖼" FontSize="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Sin imagen seleccionada"
                                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Botones de imagen -->
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BrowseImageButton"
                                    Click="OnBrowseImage"
                                    Style="{DynamicResource GhostButton}"
                                    Padding="12,7" FontSize="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📂" Margin="0,0,6,0" />
                                    <TextBlock Text="Seleccionar imagen" />
                                </StackPanel>
                            </Button>
                            <Button Style="{DynamicResource GhostButton}"
                                    Command="{Binding ClearImageCommand}"
                                    Padding="12,7" FontSize="12"
                                    Foreground="{DynamicResource AccentRedBrush}"
                                    Margin="8,0,0,0"
                                    Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✕" Margin="0,0,6,0" />
                                    <TextBlock Text="Quitar imagen" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Reglas de la estrategia ── -->
                <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Reglas de la estrategia"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource CyanGlowBrush}"
                                   Margin="0,0,0,16" />

                        <!-- Lista de reglas -->
                        <ItemsControl ItemsSource="{Binding Rules}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                            CornerRadius="6" Margin="0,0,0,6" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Número de regla -->
                                            <Border Grid.Column="0" Width="22" Height="22"
                                                    CornerRadius="11"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="{Binding OrderIndex, StringFormat={}{0}}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#0A0E1A"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Texto editable de la regla -->
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderThickness="0"
                                                     FontSize="12"
                                                     TextWrapping="Wrap"
                                                     VerticalAlignment="Center" />

                                            <!-- Botón eliminar -->
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource RemoveRuleButton}"
                                                    Command="{Binding DataContext.RemoveRuleCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Eliminar regla">
                                                <TextBlock Text="✕" FontSize="11" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Añadir nueva regla -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewRuleText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="Escribe una regla y presiona Agregar…"
                                     FontSize="12">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return"
                                                Command="{Binding AddRuleCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Command="{Binding AddRuleCommand}"
                                    Style="{DynamicResource PrimaryButton}"
                                    Margin="8,0,0,0"
                                    Height="40" Padding="14,0" FontSize="12">
                                <TextBlock Text="+ Agregar" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Botón guardar estrategia -->
                <Button Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Height="44" FontSize="14" FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Content" Value="Guardar estrategia" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Content" Value="Guardando…" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
