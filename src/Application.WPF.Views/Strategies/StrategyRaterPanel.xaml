<UserControl x:Class="Application.WPF.Views.Strategies.StrategyRaterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Strategies;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:StrategyRaterViewModel}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />

        <Style x:Key="RatingChip" TargetType="ListBoxItem">
            <Setter Property="Height"                     Value="30" />
            <Setter Property="Margin"                     Value="2,0" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="HorizontalAlignment"        Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment"   Value="Center" />
            <Setter Property="Foreground"                 Value="#777799" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" CornerRadius="6"
                                Background="#0A0E1A"
                                BorderBrush="#2A2D45" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"  Value="#1A00D4FF" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#00D4FF" />
                                <Setter Property="Foreground"                  Value="#00D4FF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background"  Value="#00D4FF" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#00D4FF" />
                                <Setter Property="Foreground"                  Value="#0A0E1A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#0F1117" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Encabezado ── -->
            <Border Grid.Row="0" Background="#161B27" CornerRadius="8,8,0,0" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="3" Height="16" CornerRadius="1.5"
                                    Background="#00D4FF" Margin="0,0,8,0"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{loc:Tr Strategy_RaterTitle}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#00D4FF"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding StrategyTitle}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Visibility="{Binding HasRatings, Converter={StaticResource BoolToVisibility}}">
                        <Border CornerRadius="8" Padding="12,8" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="#00D4FF" Opacity="0.08" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#00D4FF" Opacity="0.35" />
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Strategy_RaterAvgLabel}" FontSize="8" FontWeight="Bold"
                                           Foreground="#888888" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding AverageRatingDisplay}"
                                           FontSize="18" FontWeight="Bold"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF5555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQualified}" Value="True">
                                                    <Setter Property="Foreground" Value="#00E676" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Mensajes ── -->
            <StackPanel Grid.Row="1" Margin="18,8,18,0">
                <Border Background="#1A00E676" BorderBrush="#00E676" BorderThickness="1"
                        CornerRadius="6" Padding="10,6"
                        Visibility="{Binding GeneralSuccess, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralSuccess}" FontSize="11"
                               Foreground="#00E676" TextWrapping="Wrap" />
                </Border>
                <Border Background="#1AFF4444" BorderBrush="#FF5555" BorderThickness="1"
                        CornerRadius="6" Padding="10,6" Margin="0,4,0,0"
                        Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralError}" FontSize="11"
                               Foreground="#FF5555" TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- Sin confluencias configuradas -->
            <Border Grid.Row="2" Margin="18,12,18,8" Padding="16,14" CornerRadius="8"
                    Background="#161B27" VerticalAlignment="Top"
                    Visibility="{Binding HasNoConfluences, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Tr Strategy_NoConfluences}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#FFB300"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{loc:Tr Strategy_NoConfluencesHint}"
                               FontSize="11" Foreground="#666688"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- ── Lista de confluencias ── -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Margin="0,8,0,0" Padding="18,0,18,4">
                <ItemsControl ItemsSource="{Binding Confluences}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#161B27" CornerRadius="8"
                                    Margin="0,0,0,8" Padding="14,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="22" Height="22" CornerRadius="11"
                                                BorderBrush="#00D4FF" BorderThickness="1"
                                                Margin="0,0,10,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#00D4FF" Opacity="0.1" />
                                            </Border.Background>
                                            <TextBlock Text="{Binding DisplayIndex}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#00D4FF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Description}"
                                                   FontSize="12" Foreground="White"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />

                                        <Border Grid.Column="2" CornerRadius="4"
                                                Padding="7,2" Margin="8,0,0,0"
                                                Visibility="{Binding IsRated, Converter={StaticResource BoolToVisibility}}">
                                            <Border.Background>
                                                <SolidColorBrush Color="#00D4FF" Opacity="0.12" />
                                            </Border.Background>
                                            <TextBlock Text="{Binding RatingDisplay}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#00D4FF" />
                                        </Border>
                                    </Grid>

                                    <Rectangle Grid.Row="1" Height="1" Fill="#1E2233"
                                               VerticalAlignment="Center" />

                                    <ListBox Grid.Row="2"
                                             ItemsSource="{Binding RelativeSource=
                                             {RelativeSource AncestorType=UserControl},
                                             Path=DataContext.RatingValues}"
                                             SelectedValue="{Binding Rating, Mode=TwoWay}"
                                             ItemContainerStyle="{StaticResource RatingChip}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Tag="{Binding}"
                                             PreviewMouseLeftButtonDown="OnRatingClick">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1" Columns="10" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="{Binding RelativeSource=
                                                           {RelativeSource AncestorType=ListBoxItem},
                                                           Path=Foreground}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Pie ── -->
            <Border Grid.Row="3" Background="#161B27" CornerRadius="0,0,8,8" Padding="18,12">
                <TextBlock Text="{loc:Tr Strategy_RaterHint}"
                           FontSize="9" Foreground="#444466"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Border>
</UserControl>
