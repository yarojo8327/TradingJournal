<UserControl x:Class="Application.WPF.Views.Settings.EmotionalStatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Settings;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EmotionalStatesViewModel}"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,24" MaxWidth="600">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Border Width="4" Height="24" CornerRadius="2"
                        Background="{DynamicResource CyanGlowBrush}" Margin="0,0,12,0" />
                <TextBlock Text="{loc:Tr Settings_EmotionalStates}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{loc:Tr Settings_EmotionalStatesDesc}"
                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,24" TextWrapping="Wrap" />

            <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,14"
                    Visibility="{Binding ErrorText, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorText}" FontSize="12"
                           Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
            </Border>

            <!-- Add row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource FormTextBox}"
                         Tag="{loc:Tr Settings_NewItemPlaceholder}" />
                <Button Grid.Column="2"
                        Content="{loc:Tr Settings_Add}"
                        Style="{DynamicResource PrimaryButton}"
                        Height="36" Padding="18,0"
                        Command="{Binding AddCommand}" />
            </Grid>

            <!-- List -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8">
                <ItemsControl ItemsSource="{Binding Items}" Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,9" CornerRadius="6" Margin="2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0AFFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Width="28" Height="28"
                                            CommandParameter="{Binding}"
                                            Command="{Binding DataContext.DeleteCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" CornerRadius="4" Background="Transparent">
                                                    <TextBlock Text="✕" FontSize="11"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#1AFF4444" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
