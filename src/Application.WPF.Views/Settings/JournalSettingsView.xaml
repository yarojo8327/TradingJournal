<UserControl x:Class="Application.WPF.Views.Settings.JournalSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Settings;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:JournalSettingsViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource CyanGlowBrush}" />
            <Setter Property="Margin"     Value="0,0,0,12" />
        </Style>

        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Width"  Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="4" Background="Transparent">
                            <TextBlock Text="✕" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1AFF4444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,24" MaxWidth="920">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Border Width="4" Height="24" CornerRadius="2"
                        Background="{DynamicResource CyanGlowBrush}" Margin="0,0,12,0" />
                <TextBlock Text="{loc:Tr Settings_JournalTitle}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Text="{loc:Tr Settings_JournalSubtitle}"
                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,28" TextWrapping="Wrap" />

            <!-- Error banner -->
            <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,14"
                    Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding GeneralError}" FontSize="12"
                           Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
            </Border>

            <!-- Two columns -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ── Estados emocionales ── -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_EmotionalStates}" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="{loc:Tr Settings_EmotionalStatesDesc}"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,14" TextWrapping="Wrap" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewEmotionalState, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="{loc:Tr Settings_NewItemPlaceholder}" />
                            <Button Grid.Column="2"
                                    Content="{loc:Tr Settings_Add}"
                                    Style="{DynamicResource PrimaryButton}"
                                    Height="36" Padding="14,0"
                                    Command="{Binding AddEmotionalStateCommand}" />
                        </Grid>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" MinHeight="180" MaxHeight="380">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding EmotionalStates}" Margin="4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,7" CornerRadius="4" Margin="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#0AFFFFFF" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource DeleteBtn}"
                                                            CommandParameter="{Binding}"
                                                            Command="{Binding DataContext.DeleteEmotionalStateCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Tipos de error ── -->
                <Border Grid.Column="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_MistakeTypes}" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="{loc:Tr Settings_MistakeTypesDesc}"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,14" TextWrapping="Wrap" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewMistakeType, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="{loc:Tr Settings_NewItemPlaceholder}" />
                            <Button Grid.Column="2"
                                    Content="{loc:Tr Settings_Add}"
                                    Style="{DynamicResource PrimaryButton}"
                                    Height="36" Padding="14,0"
                                    Command="{Binding AddMistakeTypeCommand}" />
                        </Grid>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" MinHeight="180" MaxHeight="380">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MistakeTypes}" Margin="4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,7" CornerRadius="4" Margin="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#0AFFFFFF" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource DeleteBtn}"
                                                            CommandParameter="{Binding}"
                                                            Command="{Binding DataContext.DeleteMistakeTypeCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
