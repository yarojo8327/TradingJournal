<UserControl x:Class="Application.WPF.Views.Settings.SymbolMappingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Settings;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SymbolMappingsViewModel}"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Border Width="4" Height="24" CornerRadius="2"
                        Background="{DynamicResource CyanGlowBrush}" Margin="0,0,12,0" />
                <TextBlock Text="{loc:Tr Settings_SymbolsTitle}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{loc:Tr Settings_SymbolsSubtitle}"
                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Add / Edit form -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="20,16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource CyanGlowBrush}"
                           Margin="0,0,0,12"
                           Text="{loc:Tr Settings_SymAdd}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{loc:Tr Settings_SymBroker}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NewBrokerSymbol, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource FormTextBox}"
                                 Tag="EURUSD.sc" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{loc:Tr Settings_SymCanonical}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NewCanonicalName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource FormTextBox}"
                                 Tag="EURUSD" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="{loc:Tr Settings_SymCategory}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding NewCategory}"
                                  Style="{DynamicResource FormComboBox}" />
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="{loc:Tr Settings_SymValuePerPoint}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NewValuePerPoint, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource FormTextBox}"
                                 Tag="100000" />
                    </StackPanel>

                    <Button Grid.Column="8"
                            Content="{loc:Tr Settings_SymSave}"
                            Style="{DynamicResource PrimaryButton}"
                            Height="36" Padding="18,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding SaveCommand}" />

                    <Button Grid.Column="10"
                            Content="{loc:Tr Settings_SymCancel}"
                            Style="{DynamicResource GhostButton}"
                            Height="36" Padding="14,0"
                            VerticalAlignment="Bottom"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding CancelEditCommand}" />
                </Grid>

                <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,12,0,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                               Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource FormTextBox}"
                     Tag="{loc:Tr Settings_SymSearch}" />
        </Grid>

        <!-- Table -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <!-- Empty state -->
                <TextBlock Text="{loc:Tr Settings_SymEmpty}"
                           FontSize="14" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding FilteredItems.Count,
                               Converter={StaticResource BoolToVisibility},
                               ConverterParameter=invert}" />

                <DataGrid ItemsSource="{Binding FilteredItems}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#05FFFFFF"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          FontSize="13">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"   Value="Transparent" />
                            <Setter Property="Foreground"   Value="{DynamicResource TextMutedBrush}" />
                            <Setter Property="FontSize"     Value="11" />
                            <Setter Property="FontWeight"   Value="SemiBold" />
                            <Setter Property="Padding"      Value="12,8" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="BorderBrush"  Value="{DynamicResource BorderBrush}" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0AFFFFFF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background"   Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding"      Value="12,6" />
                            <Setter Property="Foreground"   Value="{DynamicResource TextPrimaryBrush}" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:Tr Settings_SymBroker}"
                                            Binding="{Binding BrokerSymbol}"
                                            Width="200" />
                        <DataGridTextColumn Header="{loc:Tr Settings_SymCanonical}"
                                            Binding="{Binding CanonicalName}"
                                            Width="160" />
                        <DataGridTextColumn Header="{loc:Tr Settings_SymCategory}"
                                            Binding="{Binding Category}"
                                            Width="120" />
                        <DataGridTextColumn Header="{loc:Tr Settings_SymValuePerPoint}"
                                            Binding="{Binding ValuePerPoint, StringFormat='0.####'}"
                                            Width="130" />
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                Margin="0,2">
                                        <Button Content="{loc:Tr Settings_SymEdit}"
                                                Style="{DynamicResource GhostButton}"
                                                FontSize="11" Padding="10,4"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.StartEditCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        <Button Content="{loc:Tr Settings_SymDelete}"
                                                Style="{DynamicResource GhostButton}"
                                                FontSize="11" Padding="10,4" Margin="4,0,0,0"
                                                Foreground="{DynamicResource AccentRedBrush}"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</UserControl>
