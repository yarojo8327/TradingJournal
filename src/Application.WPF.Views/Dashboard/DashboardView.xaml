<UserControl x:Class="Application.WPF.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels;assembly=Application.WPF.ViewModels"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="28,24,28,28">

            <!-- ══ Page header ══ -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="3" Height="22" CornerRadius="2"
                                Background="{DynamicResource PrimaryBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="{loc:Tr Dashboard_Title}"
                                   Style="{DynamicResource H1}" FontSize="22"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{DynamicResource Caption}" Margin="13,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{loc:Tr Dashboard_NewTrade}"
                            Style="{DynamicResource PrimaryButton}" Margin="0,0,10,0" />
                    <Button Content="{loc:Tr Dashboard_Refresh}"
                            Style="{DynamicResource SecondaryButton}"
                            Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>

            <!-- ══ KPI cards ══ -->
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <Border Style="{DynamicResource StatCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Kpi_TotalTrades}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="0" Style="{DynamicResource CyanLabel}" Margin="0,8,0,4" />
                        <TextBlock Text="{loc:Tr Kpi_AllTime}" Style="{DynamicResource Caption}" />
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource StatCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Kpi_WinRate}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="0%" Style="{DynamicResource CyanLabel}" Margin="0,8,0,4" />
                        <TextBlock Text="{loc:Tr Kpi_Last30Days}" Style="{DynamicResource Caption}" />
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource StatCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Kpi_NetPnl}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="$0.00" Style="{DynamicResource PositiveLabel}" Margin="0,8,0,4" />
                        <TextBlock Text="{loc:Tr Kpi_ThisMonth}" Style="{DynamicResource Caption}" />
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Kpi_AvgRR}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="0.0" Style="{DynamicResource CyanLabel}" Margin="0,8,0,4" />
                        <TextBlock Text="{loc:Tr Kpi_RiskReward}" Style="{DynamicResource Caption}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ══ Main panels ══ -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Recent trades panel -->
                <Border Grid.Column="0" Style="{DynamicResource AccentCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr Trades_RecentTrades}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{loc:Tr Trades_ViewAll}"
                                       FontSize="11"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Right" Cursor="Hand" />
                        </Grid>

                        <!-- Table header -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr Trades_Symbol}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Column="1" Text="{loc:Tr Trades_Side}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Column="2" Text="{loc:Tr Trades_Result}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Column="3" Text="{loc:Tr Trades_Pnl}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,12" />

                        <!-- Empty state -->
                        <Border Padding="0,32">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{loc:Tr Trades_Empty}"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Tr Trades_EmptyHint}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Quick actions panel -->
                <Border Grid.Column="2" Style="{DynamicResource AccentCard}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Actions_QuickActions}"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,16" />

                        <Button Content="{loc:Tr Dashboard_NewTrade}"
                                Style="{DynamicResource PrimaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                        <Button Content="{loc:Tr Dashboard_ImportCsv}"
                                Style="{DynamicResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                        <Button Content="{loc:Tr Dashboard_SampleDialog}"
                                Style="{DynamicResource GhostButton}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ShowSampleDialogCommand}" />

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,16" />

                        <TextBlock Text="{loc:Tr Actions_MarketStatus}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8" Fill="#00E676"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Tr Actions_ForexOpen}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#FFD600"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Tr Actions_FuturesPremarket}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
