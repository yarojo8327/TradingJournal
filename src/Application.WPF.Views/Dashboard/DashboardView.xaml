<UserControl x:Class="Application.WPF.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:PctToWidthConverter x:Key="PctToWidth" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- KPI card style -->
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="10" />
            <Setter Property="Padding"         Value="18,16" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="1" Opacity="0.35" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section title label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Margin"     Value="0,0,0,10" />
        </Style>

        <!-- Positive value -->
        <Style x:Key="PosValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
        </Style>

        <!-- Negative value -->
        <Style x:Key="NegValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
        </Style>

        <!-- Neutral value -->
        <Style x:Key="NeutValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource CyanGlowBrush}" />
        </Style>

        <!-- Small tag badge -->
        <Style x:Key="TagBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding"      Value="6,2" />
            <Setter Property="Background"   Value="#1500D4FF" />
        </Style>

        <!-- Bar track background -->
        <Style x:Key="BarTrack" TargetType="Border">
            <Setter Property="Height"       Value="6" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background"   Value="#20FFFFFF" />
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="24,20,24,28">

            <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <Border Width="3" Height="22" CornerRadius="2"
                                Background="{DynamicResource CyanGlowBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="Panel de Trading"
                                   Style="{DynamicResource H1}" FontSize="21"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding LastRefreshed}"
                               Style="{DynamicResource Caption}" Margin="13,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄  Actualizar"
                            Style="{DynamicResource SecondaryButton}"
                            Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>

            <!-- ══ ROW 1: KPI CARDS (6 cols) ══════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Total Trades -->
                <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="📊" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="OPERACIONES" Style="{StaticResource SectionLabel}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="{Binding TotalTrades}" Style="{StaticResource NeutValue}" Margin="0,4,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource TagBadge}" Margin="0,0,4,0">
                                <TextBlock FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentGreenBrush}">
                                    <Run Text="✔ " /><Run Text="{Binding WinCount}" />
                                </TextBlock>
                            </Border>
                            <Border Style="{StaticResource TagBadge}" Background="#15FF4444">
                                <TextBlock FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentRedBrush}">
                                    <Run Text="✘ " /><Run Text="{Binding LossCount}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Win Rate -->
                <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="🎯" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="WIN RATE" Style="{StaticResource SectionLabel}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="{Binding WinRateLabel}" Style="{StaticResource NeutValue}" Margin="0,4,0,6" />
                        <!-- mini bar -->
                        <Border Style="{StaticResource BarTrack}">
                            <Border x:Name="WinRateBar" CornerRadius="3" Height="6"
                                    HorizontalAlignment="Left" Background="{DynamicResource CyanGlowBrush}" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Net P&L (Mes) -->
                <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="📅" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="P&amp;L ESTE MES" Style="{StaticResource SectionLabel}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="{Binding NetPnlMonthLabel}"
                                   Margin="0,4,0,6"
                                   FontSize="22" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NetPnlMonthPositive}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="vs. mes corriente" Style="{StaticResource Caption}" />
                    </StackPanel>
                </Border>

                <!-- Net P&L Total -->
                <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="💰" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="P&amp;L TOTAL" Style="{StaticResource SectionLabel}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="{Binding NetPnlTotalLabel}"
                                   Margin="0,4,0,6"
                                   FontSize="22" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NetPnlTotalPositive}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="acumulado histórico" Style="{StaticResource Caption}" />
                    </StackPanel>
                </Border>

                <!-- Avg R:R -->
                <Border Grid.Column="8" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="⚖️" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="RIESGO/REWARD" Style="{StaticResource SectionLabel}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="{Binding AvgRRLabel}" Style="{StaticResource NeutValue}" Margin="0,4,0,6" />
                        <TextBlock Text="promedio" Style="{StaticResource Caption}" />
                    </StackPanel>
                </Border>

                <!-- Profit Factor -->
                <Border Grid.Column="10" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="⚡" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="PROFIT FACTOR" Style="{StaticResource SectionLabel}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="{Binding ProfitFactorLabel}" Style="{StaticResource NeutValue}" Margin="0,4,0,6" />
                        <TextBlock Text="ratio ganancia/pérdida" Style="{StaticResource Caption}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ ACCESO RÁPIDO ══════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Bitácora -->
                <Button Grid.Column="0" Style="{DynamicResource GhostButton}"
                        Command="{Binding GoToJournalCommand}" Cursor="Hand" Padding="0" Height="44">
                    <Border CornerRadius="8" Background="#0A00D4FF" Width="300" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📓" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="BITÁCORA" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource CyanGlowBrush}" />
                                <TextBlock Text="Ver operaciones" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Análisis -->
                <Button Grid.Column="2" Style="{DynamicResource GhostButton}"
                        Command="{Binding GoToAnalyticsCommand}" Cursor="Hand" Padding="0" Height="44">
                    <Border CornerRadius="8" Background="#0A00D4FF" Width="300" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📈" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ANÁLISIS" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource CyanGlowBrush}" />
                                <TextBlock Text="Estadísticas" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Estrategias -->
                <Button Grid.Column="4" Style="{DynamicResource GhostButton}"
                        Command="{Binding GoToStrategiesCommand}" Cursor="Hand" Padding="0" Height="44">
                    <Border CornerRadius="8" Background="#0A00D4FF" Width="300" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ESTRATEGIAS" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource CyanGlowBrush}" />
                                <TextBlock Text="Gestionar playbook" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Playbook -->
                <Button Grid.Column="6" Style="{DynamicResource GhostButton}"
                        Command="{Binding GoToPlaybookCommand}" Cursor="Hand" Padding="0" Height="44">
                    <Border CornerRadius="8" Background="#0A00D4FF" Width="300" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🏆" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PLAYBOOK" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource CyanGlowBrush}" />
                                <TextBlock Text="Trades destacados" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Cuentas -->
                <Button Grid.Column="8" Style="{DynamicResource GhostButton}"
                        Command="{Binding GoToAccountCommand}" Cursor="Hand" Padding="0" Height="44">
                    <Border CornerRadius="8" Background="#0A00D4FF" Width="300" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="💼" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CUENTAS" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource CyanGlowBrush}" />
                                <TextBlock Text="Gestionar cuentas" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>

            <!-- ══ ROW 2: CURVA DE EQUITY  +  DISTRIBUCIÓN  +  CAPITAL ════════ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Equity curve card -->
                <Border Grid.Column="0" Style="{DynamicResource AccentCard}" Padding="16,14,16,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="CURVA DE EQUITY" Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" />
                            <TextBlock Text="Ver análisis →" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Cursor="Hand">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding GoToAnalyticsCommand}" />
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>
                        <!-- Canvas container — code-behind draws here -->
                        <Border Height="130" Background="#08FFFFFF" CornerRadius="6"
                                ClipToBounds="True">
                            <Canvas x:Name="EquityCanvas"
                                    SizeChanged="OnEquityCanvasSizeChanged" />
                        </Border>
                        <!-- no-data placeholder -->
                        <TextBlock x:Name="EquityNoData"
                                   Text="Sin operaciones cerradas aún"
                                   Style="{StaticResource Caption}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Win/Loss/Open distribution -->
                <Border Grid.Column="2" Style="{DynamicResource Card}" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="DISTRIBUCIÓN" Style="{StaticResource SectionLabel}" />

                        <!-- Win -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentGreenBrush}"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Win" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource BarTrack}" Margin="0,0,8,0">
                                <Border CornerRadius="3" Height="6" HorizontalAlignment="Left"
                                        Background="{DynamicResource AccentGreenBrush}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PctToWidth}">
                                            <Binding Path="WinPct" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" Path="ActualWidth" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock Grid.Column="2" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentGreenBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding WinPct, StringFormat={}{0:F0}}" /><Run Text="%" />
                            </TextBlock>
                        </Grid>

                        <!-- Loss -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentRedBrush}"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Loss" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource BarTrack}" Margin="0,0,8,0">
                                <Border CornerRadius="3" Height="6" HorizontalAlignment="Left"
                                        Background="{DynamicResource AccentRedBrush}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PctToWidth}">
                                            <Binding Path="LossPct" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" Path="ActualWidth" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock Grid.Column="2" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding LossPct, StringFormat={}{0:F0}}" /><Run Text="%" />
                            </TextBlock>
                        </Grid>

                        <!-- Open -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#FFD600"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Open" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource BarTrack}" Margin="0,0,8,0">
                                <Border CornerRadius="3" Height="6" HorizontalAlignment="Left"
                                        Background="#FFD600">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PctToWidth}">
                                            <Binding Path="OpenPct" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" Path="ActualWidth" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock Grid.Column="2" FontSize="11" FontWeight="Bold"
                                       Foreground="#FFD600"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding OpenPct, StringFormat={}{0:F0}}" /><Run Text="%" />
                            </TextBlock>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,14,0,14" />

                        <!-- Racha & factor -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MEJOR RACHA" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding BestStreakLabel}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource CyanGlowBrush}" />
                                <TextBlock Text="wins seguidos" Style="{StaticResource Caption}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="EN ABIERTO" Style="{StaticResource SectionLabel}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding OpenCount}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#FFD600" />
                                <TextBlock Text="posiciones" Style="{StaticResource Caption}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Capital summary -->
                <Border Grid.Column="4" Style="{DynamicResource Card}" Padding="16,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="RESUMEN DE CAPITAL" Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" />
                            <TextBlock Text="Cuentas →" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding GoToAccountCommand}" />
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Capital inicial" Style="{StaticResource Caption}" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding TotalInitialCapital}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Capital actual" Style="{StaticResource Caption}" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding TotalCurrentCapital}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,10" />

                        <TextBlock Text="Ganancia / Pérdida" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding TotalGainLoss}"
                                   FontSize="20" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCapitalPositive}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding TotalGainLossPct}"
                                   FontSize="12" FontWeight="SemiBold" Margin="0,2,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCapitalPositive}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,10" />

                        <!-- Playbook summary -->
                        <Grid Margin="0,0,0,0">
                            <TextBlock Text="PLAYBOOK" Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" />
                            <TextBlock Text="Ver →" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding GoToPlaybookCommand}" />
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border Background="#1500D4FF" CornerRadius="5" Padding="8,4" Margin="0,0,8,0">
                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource CyanGlowBrush}">
                                    <Run Text="{Binding PlaybookCount}" /><Run Text=" registros" />
                                </TextBlock>
                            </Border>
                            <Border Background="#15FFD700" CornerRadius="5" Padding="8,4">
                                <TextBlock Text="{Binding PlaybookAvgRatingLabel}"
                                           FontSize="13" FontWeight="Bold" Foreground="#FFD700" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ ROW 3: TRADES RECIENTES  +  ESTRATEGIAS  +  SÍMBOLOS  +  SESIÓN ══ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Trades recientes -->
                <Border Grid.Column="0" Style="{DynamicResource AccentCard}" Padding="16,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="ÚLTIMAS OPERACIONES" Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" />
                            <TextBlock Text="Ver bitácora →" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding GoToJournalCommand}" />
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>

                        <!-- Header -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SÍMBOLO"  Style="{StaticResource SectionLabel}" Margin="0" />
                            <TextBlock Grid.Column="1" Text="DIR"      Style="{StaticResource SectionLabel}" Margin="0" />
                            <TextBlock Grid.Column="2" Text="RESULTADO" Style="{StaticResource SectionLabel}" Margin="0" />
                            <TextBlock Grid.Column="3" Text="P&amp;L"  Style="{StaticResource SectionLabel}" Margin="0" HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="4" Text="FECHA"    Style="{StaticResource SectionLabel}" Margin="8,0,0,0" HorizontalAlignment="Right" />
                        </Grid>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,8" />

                        <!-- Rows via ItemsControl -->
                        <ItemsControl ItemsSource="{Binding RecentTrades}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <!-- Direction badge -->
                                        <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1500D4FF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="S">
                                                            <Setter Property="Background" Value="#15FF4444" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Direction}" FontSize="10" FontWeight="Bold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource CyanGlowBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Direction}" Value="S">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <!-- Result -->
                                        <TextBlock Grid.Column="2" Text="{Binding Result}"
                                                   FontSize="11" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsProfit}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsLoss}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- P&L -->
                                        <TextBlock Grid.Column="3" Text="{Binding PnLLabel}"
                                                   FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLoss}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Date -->
                                        <TextBlock Grid.Column="4" Text="{Binding Date}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <Border Padding="0,20">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Aún no hay operaciones registradas"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Strategy performance -->
                <Border Grid.Column="2" Style="{DynamicResource Card}" Padding="16,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="RENDIMIENTO POR ESTRATEGIA" Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" />
                            <TextBlock Text="Ver →" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding GoToStrategiesCommand}" />
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding StrategyStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding WinRateLabel}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource CyanGlowBrush}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <!-- Bar -->
                                        <Border Style="{StaticResource BarTrack}">
                                            <Border CornerRadius="3" Height="6"
                                                    HorizontalAlignment="Left"
                                                    Background="{DynamicResource CyanGlowBrush}">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource PctToWidth}">
                                                        <Binding Path="BarWidth" />
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" Path="ActualWidth" />
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}">
                                                <Run Text="{Binding TradeCount}" /><Run Text=" ops · " />
                                            </TextBlock>
                                            <TextBlock Text="{Binding PnLLabel}" FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPnLPositive}" Value="False">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Sin datos de estrategias"
                                   HorizontalAlignment="Center" Margin="0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Símbolos + Sesión (stacked) -->
                <StackPanel Grid.Column="4">
                    <!-- Top símbolos -->
                    <Border Style="{DynamicResource Card}" Padding="16,14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="TOP SÍMBOLOS" Style="{StaticResource SectionLabel}" />
                            <ItemsControl ItemsSource="{Binding SymbolStats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource CyanGlowBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Style="{StaticResource BarTrack}" Margin="4,0">
                                                <Border CornerRadius="3" Height="6"
                                                        HorizontalAlignment="Left"
                                                        Background="{DynamicResource CyanGlowBrush}" Opacity="0.7">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PctToWidth}">
                                                            <Binding Path="BarPct" />
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" Path="ActualWidth" />
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Count}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Sin datos"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Sesión -->
                    <Border Style="{DynamicResource Card}" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="POR SESIÓN" Style="{StaticResource SectionLabel}" />
                            <ItemsControl ItemsSource="{Binding SessionStats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                       FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Style="{StaticResource BarTrack}" Margin="4,0">
                                                <Border CornerRadius="3" Height="6"
                                                        HorizontalAlignment="Left" Background="#FFD700" Opacity="0.85">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PctToWidth}">
                                                            <Binding Path="BarPct" />
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" Path="ActualWidth" />
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Count}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Sin datos de sesión"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
