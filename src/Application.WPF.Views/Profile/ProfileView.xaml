<UserControl x:Class="Application.WPF.Views.Profile.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Profile;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProfileViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="40,32,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="560" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" MaxWidth="480" />
            </Grid.ColumnDefinitions>

            <!-- COLUMNA IZQUIERDA — Datos del perfil -->
            <StackPanel Grid.Column="0">

                <StackPanel Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="3" Height="20" CornerRadius="1.5"
                                Background="{DynamicResource CyanGlowBrush}"
                                Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr Profile_Title}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{loc:Tr Profile_Subtitle}"
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="13,0,0,0" />
                </StackPanel>

                <!-- Avatar + resumen -->
                <Border Style="{DynamicResource AccentCard}" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="{DynamicResource CyanGlowBrush}"
                                Margin="0,0,16,0">
                            <TextBlock Text="{Binding Username[0], FallbackValue=?}"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#0A0E1A"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding FullName}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Email}"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="3" Background="#1500D4FF"
                                        BorderBrush="#2200D4FF" BorderThickness="1" Padding="6,2">
                                    <TextBlock Text="{loc:Tr Profile_MemberSince}"
                                               FontSize="10" Foreground="#00D4FF" />
                                </Border>
                                <TextBlock Text="{Binding MemberSince}"
                                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Formulario perfil -->
                <Border Style="{DynamicResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Profile_PersonalInfo}"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,20" />

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{loc:Tr Profile_FullName}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <TextBox Grid.Row="1" x:Name="FullNameBox"
                                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=FullNameBox}"
                                       FontSize="11" Foreground="{DynamicResource AccentRedBrush}" Margin="2,4,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{loc:Tr Profile_Email}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <TextBox Grid.Row="1" x:Name="EmailBox"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=EmailBox}"
                                       FontSize="11" Foreground="{DynamicResource AccentRedBrush}" Margin="2,4,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{loc:Tr Profile_Username}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <TextBox Grid.Row="1" x:Name="UsernameBox"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=UsernameBox}"
                                       FontSize="11" Foreground="{DynamicResource AccentRedBrush}" Margin="2,4,0,0" />
                        </Grid>

                        <Border Margin="0,0,0,16" Padding="12,8" CornerRadius="5"
                                Background="#22FF3333" BorderBrush="{DynamicResource AccentRedBrush}"
                                BorderThickness="1"
                                Visibility="{Binding ProfileError, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding ProfileError}" FontSize="12"
                                       Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                        </Border>

                        <Border Margin="0,0,0,16" Padding="12,8" CornerRadius="5"
                                Background="#2200E676" BorderBrush="{DynamicResource AccentGreenBrush}"
                                BorderThickness="1"
                                Visibility="{Binding ProfileSuccess, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding ProfileSuccess}" FontSize="12"
                                       Foreground="{DynamicResource AccentGreenBrush}" TextWrapping="Wrap" />
                        </Border>

                        <Button Content="{loc:Tr Profile_SaveChanges}"
                                Style="{DynamicResource PrimaryButton}"
                                HorizontalAlignment="Left" Padding="24,10"
                                Command="{Binding SaveProfileCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- COLUMNA DERECHA — Cambiar contraseña -->
            <StackPanel Grid.Column="2">

                <StackPanel Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="3" Height="20" CornerRadius="1.5"
                                Background="{DynamicResource AccentRedBrush}"
                                Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr Profile_Security_Title}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{loc:Tr Profile_Security_Subtitle}"
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="13,0,0,0" />
                </StackPanel>

                <Border Style="{DynamicResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Profile_AccountSecurity}"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,20" />

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr Profile_CurrentPassword}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <PasswordBox x:Name="CurrentPasswordBox"
                                         Style="{DynamicResource FormPasswordBox}"
                                         PasswordChanged="CurrentPasswordBox_Changed" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{loc:Tr Profile_NewPassword}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <PasswordBox x:Name="NewPasswordBox"
                                         Style="{DynamicResource FormPasswordBox}"
                                         PasswordChanged="NewPasswordBox_Changed" />
                            <ItemsControl x:Name="NewPasswordErrors" Margin="2,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource AccentRedBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="{loc:Tr Profile_ConfirmNewPassword}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <PasswordBox x:Name="ConfirmNewPasswordBox"
                                         Style="{DynamicResource FormPasswordBox}"
                                         PasswordChanged="ConfirmNewPasswordBox_Changed" />
                            <ItemsControl x:Name="ConfirmNewPasswordErrors" Margin="2,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource AccentRedBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Margin="0,0,0,16" Padding="12,8" CornerRadius="5"
                                Background="#22FF3333" BorderBrush="{DynamicResource AccentRedBrush}"
                                BorderThickness="1"
                                Visibility="{Binding PasswordError, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding PasswordError}" FontSize="12"
                                       Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                        </Border>

                        <Border Margin="0,0,0,16" Padding="12,8" CornerRadius="5"
                                Background="#2200E676" BorderBrush="{DynamicResource AccentGreenBrush}"
                                BorderThickness="1"
                                Visibility="{Binding PasswordSuccess, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding PasswordSuccess}" FontSize="12"
                                       Foreground="{DynamicResource AccentGreenBrush}" TextWrapping="Wrap" />
                        </Border>

                        <Button Content="{loc:Tr Profile_ChangePassword}"
                                Style="{DynamicResource SecondaryButton}"
                                HorizontalAlignment="Left" Padding="24,10"
                                Command="{Binding ChangePasswordCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

                        <Border Margin="0,20,0,0" Padding="12,10"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Profile_Requirements}"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3">
                                    <Run Text="• " /><Run Text="{loc:Tr Profile_Req_MinLength}" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3">
                                    <Run Text="• " /><Run Text="{loc:Tr Profile_Req_Uppercase}" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3">
                                    <Run Text="• " /><Run Text="{loc:Tr Profile_Req_Number}" />
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
                                    <Run Text="• " /><Run Text="{loc:Tr Profile_Req_ConfirmMatch}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
