<UserControl x:Class="Application.WPF.Views.Register.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Register;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RegisterViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Panel izquierdo: marca y beneficios -->
            <ColumnDefinition Width="2*" MinWidth="280" />
            <!-- Panel derecho: formulario -->
            <ColumnDefinition Width="3*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════
             PANEL IZQUIERDO — Marca
             ══════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E3A5F" />
            </Border.BorderBrush>
            <Border BorderThickness="0,0,1,0"
                    BorderBrush="#1E3A5F">

                <!-- Línea cyan superior del panel -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource CyanGlowBrush}" />

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                Margin="48,0,48,0">

                        <!-- Logo -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="5" Height="32" CornerRadius="2.5"
                                    Background="{DynamicResource CyanGlowBrush}"
                                    Margin="0,0,14,0" VerticalAlignment="Center" />
                            <TextBlock FontSize="28" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Text="TRADING" Foreground="#00D4FF" />
                                <Run Text="JOURNAL" Foreground="{DynamicResource TextPrimaryBrush}" />
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="Tu bitácora profesional de trading"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,48"
                                   TextWrapping="Wrap" />

                        <!-- Separador -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,0,0,36" />

                        <!-- Características -->
                        <StackPanel Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="#1500D4FF"
                                        BorderBrush="#2200D4FF" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="📊" FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Registro de operaciones"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="Lleva el control de cada trade"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="#1500E676"
                                        BorderBrush="#2200E676" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="📈" FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Análisis de rendimiento"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="Win rate, P&amp;L, R:R en tiempo real"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="#15FFD600"
                                        BorderBrush="#22FFD600" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="📋" FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Playbooks &amp; estrategias"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="Documenta y mejora tu sistema"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Separador -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,36,0,24" />

                        <!-- Badge versión -->
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="4"
                                    Background="#1500D4FF"
                                    BorderBrush="#3300D4FF" BorderThickness="1"
                                    Padding="10,4">
                                <TextBlock Text="v1.0.0 — Enterprise Edition"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#00D4FF" />
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- ══════════════════════════════════
             PANEL DERECHO — Formulario
             ══════════════════════════════════ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <Grid VerticalAlignment="Center" MinHeight="500">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Contenido centrado verticalmente -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            Margin="48,40,48,40"
                            MaxWidth="460">

                    <!-- Encabezado del formulario -->
                    <StackPanel Margin="0,0,0,32">
                        <TextBlock Text="Crear cuenta"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <Border Width="24" Height="2" CornerRadius="1"
                                    Background="{DynamicResource CyanGlowBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Completa los campos para comenzar"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Nombre completo ── -->
                    <Grid Margin="0,0,0,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Nombre completo"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox  Grid.Row="1"
                                  x:Name="FullNameBox"
                                  Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource FormTextBox}"
                                  Tag="Ej. Juan García" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=FullNameBox}"
                                   FontSize="11" Foreground="{DynamicResource AccentRedBrush}"
                                   Margin="2,4,0,0" />
                    </Grid>

                    <!-- ── Correo electrónico ── -->
                    <Grid Margin="0,0,0,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Correo electrónico"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox  Grid.Row="1"
                                  x:Name="EmailBox"
                                  Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource FormTextBox}"
                                  Tag="usuario@ejemplo.com" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=EmailBox}"
                                   FontSize="11" Foreground="{DynamicResource AccentRedBrush}"
                                   Margin="2,4,0,0" />
                    </Grid>

                    <!-- ── Nombre de usuario ── -->
                    <Grid Margin="0,0,0,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Nombre de usuario"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox  Grid.Row="1"
                                  x:Name="UsernameBox"
                                  Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource FormTextBox}"
                                  Tag="trader_pro" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=UsernameBox}"
                                   FontSize="11" Foreground="{DynamicResource AccentRedBrush}"
                                   Margin="2,4,0,0" />
                    </Grid>

                    <!-- ── Contraseña + Confirmar (dos columnas) ── -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Contraseña -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Contraseña"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <PasswordBox x:Name="PasswordBox"
                                         Style="{DynamicResource FormPasswordBox}"
                                         PasswordChanged="PasswordBox_PasswordChanged" />
                            <ItemsControl x:Name="PasswordErrors" Margin="2,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource AccentRedBrush}"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Confirmar contraseña -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Confirmar contraseña"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         Style="{DynamicResource FormPasswordBox}"
                                         PasswordChanged="ConfirmPasswordBox_PasswordChanged" />
                            <ItemsControl x:Name="ConfirmPasswordErrors" Margin="2,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource AccentRedBrush}"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- ── Requisitos de contraseña ── -->
                    <Border Margin="0,0,0,24"
                            Padding="14,10"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="REQUISITOS DE CONTRASEÑA"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="• Mínimo 8 caracteres"    FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3" />
                                <TextBlock Text="• Una letra mayúscula"    FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3" />
                                <TextBlock Text="• Una letra minúscula"    FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text=" " FontSize="9" Margin="0,0,0,8" />
                                <TextBlock Text="• Un número"                    FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3" />
                                <TextBlock Text="• Un carácter especial (!@#$…)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Error general ── -->
                    <Border Margin="0,0,0,20"
                            Padding="14,10"
                            Background="#22FF3333"
                            BorderBrush="{DynamicResource AccentRedBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="13"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Top" />
                            <TextBlock Text="{Binding GeneralError}"
                                       FontSize="12"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- ── Botón registrar ── -->
                    <Button Content="Crear cuenta"
                            Style="{DynamicResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Height="42"
                            FontSize="14"
                            Command="{Binding RegisterCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ══ Overlay de carga ══ -->
        <Border Grid.Column="1"
                Background="#CC0A0E1A"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="24"
                        Background="#1500D4FF"
                        BorderBrush="#3300D4FF" BorderThickness="1"
                        Margin="0,0,0,14">
                    <TextBlock Text="⏳" FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Registrando usuario…"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Por favor espera"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
