<UserControl x:Class="Application.WPF.Views.Register.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Register;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RegisterViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter       x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      MaxWidth="480">
            <StackPanel Margin="40,48,40,48">

                <!-- ══ Header ══ -->
                <StackPanel Margin="0,0,0,36" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Border Width="4" Height="28" CornerRadius="2"
                                Background="{DynamicResource CyanGlowBrush}"
                                Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <Run Text="TRADING" Foreground="#00D4FF" />
                            <Run Text="JOURNAL" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="Crea tu cuenta para comenzar"
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- ══ Card ══ -->
                <Border Style="{DynamicResource AccentCard}">
                    <StackPanel>

                        <TextBlock Text="REGISTRO DE USUARIO"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,24" />

                        <!-- Nombre completo -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Nombre completo"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox x:Name="FullNameBox"
                                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="Ej. Juan García" />
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=FullNameBox}"
                                       FontSize="11" Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- Correo electrónico -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Correo electrónico"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox x:Name="EmailBox"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="usuario@ejemplo.com" />
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=EmailBox}"
                                       FontSize="11" Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- Nombre de usuario -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Nombre de usuario"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox x:Name="UsernameBox"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="trader_pro" />
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=UsernameBox}"
                                       FontSize="11" Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- Contraseña -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Contraseña"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <PasswordBox x:Name="PasswordBox"
                                         Style="{DynamicResource FormPasswordBox}"
                                         PasswordChanged="PasswordBox_PasswordChanged" />
                            <ItemsControl x:Name="PasswordErrors" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentRedBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Confirmar contraseña -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="Confirmar contraseña"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         Style="{DynamicResource FormPasswordBox}"
                                         PasswordChanged="ConfirmPasswordBox_PasswordChanged" />
                            <ItemsControl x:Name="ConfirmPasswordErrors" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentRedBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Error general -->
                        <Border Background="{DynamicResource AccentRedBrush}"
                                CornerRadius="4" Padding="12,8" Margin="0,0,0,16"
                                Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding GeneralError}"
                                       FontSize="12" Foreground="White" TextWrapping="Wrap" />
                        </Border>

                        <!-- Botón registrar -->
                        <Button Content="Crear cuenta"
                                Style="{DynamicResource PrimaryButton}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

                        <!-- Reglas de contraseña -->
                        <Border Margin="0,20,0,0" Padding="12"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="La contraseña debe tener:"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="• Mínimo 8 caracteres"         FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="• Una letra mayúscula"          FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="• Una letra minúscula"          FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="• Un número"                    FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="• Un carácter especial (!@#$…)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Overlay de carga -->
        <Border Background="#AA000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Registrando usuario…"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

    </Grid>
</UserControl>
