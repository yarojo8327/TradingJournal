<UserControl x:Class="Application.WPF.Views.Login.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Login;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="280" />
            <ColumnDefinition Width="3*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════
             PANEL IZQUIERDO — Marca
             ══════════════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}">
            <Border BorderThickness="0,0,1,0" BorderBrush="#1E3A5F">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource CyanGlowBrush}" />

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="48,0,48,0">

                        <!-- Logo -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="5" Height="32" CornerRadius="2.5"
                                    Background="{DynamicResource CyanGlowBrush}"
                                    Margin="0,0,14,0" VerticalAlignment="Center" />
                            <TextBlock FontSize="28" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Text="TRADING" Foreground="#00D4FF" />
                                <Run Text="JOURNAL" Foreground="{DynamicResource TextPrimaryBrush}" />
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="{loc:Tr Login_Tagline}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,48" TextWrapping="Wrap" />

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,36" />

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="#1500D4FF" BorderBrush="#2200D4FF" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="🔐" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Tr Login_Feature_Secure}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{loc:Tr Login_Feature_SecureDesc}"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="#1500E676" BorderBrush="#2200E676" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="📊" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Tr Login_Feature_Portfolio}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{loc:Tr Login_Feature_PortfolioDesc}"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="#15FFD600" BorderBrush="#22FFD600" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="⚡" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Tr Login_Feature_Instant}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{loc:Tr Login_Feature_InstantDesc}"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,36,0,24" />

                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="4" Background="#1500D4FF"
                                    BorderBrush="#3300D4FF" BorderThickness="1" Padding="10,4">
                                <TextBlock Text="{loc:Tr App_Version}"
                                           FontSize="11" FontWeight="SemiBold" Foreground="#00D4FF" />
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- ══════════════════════════════════
             PANEL DERECHO — Formulario login
             ══════════════════════════════════ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <Grid VerticalAlignment="Center" MinHeight="400">
                <StackPanel VerticalAlignment="Center"
                            Margin="48,40,48,40"
                            MaxWidth="420">

                    <!-- Encabezado -->
                    <StackPanel Margin="0,0,0,36">
                        <TextBlock Text="{loc:Tr Login_Title}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <Border Width="24" Height="2" CornerRadius="1"
                                    Background="{DynamicResource CyanGlowBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="{loc:Tr Login_Subtitle}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Usuario o correo ── -->
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{loc:Tr Login_UsernameOrEmail}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox  Grid.Row="1"
                                  x:Name="UsernameBox"
                                  Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource FormTextBox}"
                                  Tag="{loc:Tr Login_UsernameOrEmailHint}" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=UsernameBox}"
                                   FontSize="11" Foreground="{DynamicResource AccentRedBrush}"
                                   Margin="2,4,0,0" />
                    </Grid>

                    <!-- ── Contraseña ── -->
                    <Grid Margin="0,0,0,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{loc:Tr Login_Password}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <PasswordBox Grid.Row="1"
                                     x:Name="PasswordBox"
                                     Style="{DynamicResource FormPasswordBox}"
                                     PasswordChanged="PasswordBox_PasswordChanged" />
                        <ItemsControl Grid.Row="2" x:Name="PasswordErrors" Margin="2,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11"
                                               Foreground="{DynamicResource AccentRedBrush}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- ── Error general ── -->
                    <Border Margin="0,0,0,20" Padding="14,10"
                            Background="#22FF3333"
                            BorderBrush="{DynamicResource AccentRedBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="13"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Top" />
                            <TextBlock Text="{Binding GeneralError}"
                                       FontSize="12" Foreground="{DynamicResource AccentRedBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- ── Botón ingresar ── -->
                    <Button Content="{loc:Tr Login_Submit}"
                            Style="{DynamicResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Height="42" FontSize="14"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Margin="0,0,0,20" />

                    <!-- ── Separador ── -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{loc:Tr Login_NoAccount}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="12,0" />
                        <Rectangle Grid.Column="2" Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- ── Botón ir a registro ── -->
                    <Button Content="{loc:Tr Login_CreateAccount}"
                            Style="{DynamicResource SecondaryButton}"
                            HorizontalAlignment="Stretch"
                            Height="38" FontSize="13"
                            Command="{Binding GoToRegisterCommand}" />

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ══ Overlay de carga ══ -->
        <Border Grid.Column="1" Background="#CC0A0E1A"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="24"
                        Background="#1500D4FF" BorderBrush="#3300D4FF" BorderThickness="1"
                        Margin="0,0,0,14">
                    <TextBlock Text="🔐" FontSize="22"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{loc:Tr Login_Verifying}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Tr Login_PleaseWait}"
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
