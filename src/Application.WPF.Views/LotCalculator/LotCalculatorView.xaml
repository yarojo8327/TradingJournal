<UserControl x:Class="Application.WPF.Views.LotCalculator.LotCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.LotCalculator;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LotCalculatorViewModel}"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,24,32,24" MaxWidth="900">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="4" Height="24" CornerRadius="2"
                            Background="{DynamicResource CyanGlowBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="{loc:Tr LotCalc_Title}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{loc:Tr LotCalc_Subtitle}"
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Form card -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr LotCalc_Account}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr LotCalc_Symbol}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Symbols}"
                                      SelectedItem="{Binding SelectedSymbol}"
                                      IsEditable="True"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock>
                                <Run Text="{loc:Tr LotCalc_Capital}" />
                                <Run Text=" (" /><Run Text="{Binding AccountCurrency}" /><Run Text=")" />
                            </TextBlock>
                            <TextBox Text="{Binding CapitalText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr LotCalc_RiskPercent}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding RiskPercentText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="1.0" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr LotCalc_EntryPrice}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding EntryPriceText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr LotCalc_StopLoss}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding StopLossText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr LotCalc_TakeProfit}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding TakeProfitText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" />
                        </StackPanel>
                    </Grid>

                    <!-- Error -->
                    <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                   Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                    </Border>

                    <!-- Warning (RN-002) -->
                    <Border Background="#1AFFC107" BorderBrush="#FFC107"
                            BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding WarningMessage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding WarningMessage}" FontSize="12"
                                   Foreground="#FFC107" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Result card -->
            <Border Grid.Row="2"
                    Style="{DynamicResource AccentCard}"
                    Padding="20,16" Margin="0,0,0,16"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr LotCalc_Result}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource CyanGlowBrush}"
                               Margin="0,0,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr LotCalc_LotSize}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding LotSizeText}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{loc:Tr LotCalc_RiskAmount}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding RiskAmountText}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr LotCalc_RiskReward}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding RiskRewardText}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="{loc:Tr LotCalc_Save}"
                                Style="{DynamicResource PrimaryButton}"
                                Height="36" Padding="18,0"
                                Command="{Binding SaveCalculationCommand}" />
                        <TextBlock Text="{Binding GeneralSuccess}" FontSize="12"
                                   Foreground="{DynamicResource AccentGreenBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- History -->
            <Border Grid.Row="3"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="20,16">
                <StackPanel>
                    <TextBlock Text="{loc:Tr LotCalc_History}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,10" />

                    <TextBlock Text="{loc:Tr LotCalc_HistoryEmpty}"
                               FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                               Visibility="{Binding History.Count,
                                   Converter={StaticResource BoolToVisibility},
                                   ConverterParameter=invert}" />

                    <ItemsControl ItemsSource="{Binding History}"
                                  Visibility="{Binding History.Count, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,1,0,0" Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding CreatedAt, StringFormat='dd/MM/yy HH:mm'}"
                                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Symbol}" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" FontSize="12">
                                            <Run Text="{Binding RiskPercent, StringFormat='0.##'}" /><Run Text="% — " />
                                            <Run Text="{Binding RiskAmount, StringFormat='N2'}" /><Run Text=" " /><Run Text="{Binding AccountCurrency}" />
                                        </TextBlock>
                                        <TextBlock Grid.Column="3" Text="{Binding LotSize, StringFormat='0.00'}"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource CyanGlowBrush}" />
                                        <TextBlock Grid.Column="4" FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                                            <Run Text="1:" /><Run Text="{Binding RiskRewardRatio, StringFormat='0.00'}" />
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
