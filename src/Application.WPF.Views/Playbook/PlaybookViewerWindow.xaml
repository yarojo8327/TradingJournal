<Window x:Class="Application.WPF.Views.Playbook.PlaybookViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
        mc:Ignorable="d"
        Width="1280" Height="760"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI"
        KeyDown="OnKeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="ZoomBtn" TargetType="Button">
            <Setter Property="Width"           Value="30" />
            <Setter Property="Height"          Value="30" />
            <Setter Property="Background"      Value="#20FFFFFF" />
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="14" />
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#35FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource CyanGlowBrush}" />
            <Setter Property="Margin"     Value="0,12,0,4" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── BARRA DE TÍTULO ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseDown="OnTitleBarMouseDown">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Símbolo + estrategia -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="16" CornerRadius="1.5"
                                Background="{DynamicResource CyanGlowBrush}" Margin="0,0,10,0" />
                        <TextBlock x:Name="TitleSymbol"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource CyanGlowBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TitleStrategy"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>

                    <!-- Controles de zoom (centrados) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="BtnZoomOut" Style="{StaticResource ZoomBtn}"
                                Click="OnZoomOut" ToolTip="Reducir (-)">
                            <TextBlock Text="−" FontSize="16" FontWeight="Bold" />
                        </Button>
                        <Border Background="#15FFFFFF" CornerRadius="4"
                                Padding="12,0" Margin="4,0" VerticalAlignment="Center" Height="30">
                            <TextBlock x:Name="ZoomLabel"
                                       Text="100%"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Button x:Name="BtnZoomIn" Style="{StaticResource ZoomBtn}"
                                Click="OnZoomIn" ToolTip="Ampliar (+)">
                            <TextBlock Text="+" FontSize="16" FontWeight="Bold" />
                        </Button>
                        <Button Style="{StaticResource ZoomBtn}" Margin="4,0,0,0"
                                Click="OnZoomReset" ToolTip="Restablecer (doble clic)">
                            <TextBlock Text="⊙" FontSize="14" />
                        </Button>
                    </StackPanel>

                    <!-- Hint ESC -->
                    <TextBlock Grid.Column="2"
                               Text="ESC para cerrar"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,16,0" />

                    <!-- Botón cerrar -->
                    <Button Grid.Column="3" Click="OnClose"
                            Width="36" Height="36" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="✕" FontSize="14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#20FF4444" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── CUERPO: imagen (izq) + detalles (der) ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <!-- Imagen con zoom -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceElevatedBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <!-- Placeholder sin imagen -->
                        <StackPanel x:Name="NoImagePlaceholder"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🖼️" FontSize="64"
                                       HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <TextBlock Text="Sin imagen en este registro"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- ScrollViewer + imagen zoomeable — se adapta al contenedor -->
                        <ScrollViewer x:Name="ImageScrollViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      PanningMode="Both"
                                      PreviewMouseWheel="OnMouseWheel"
                                      Visibility="Collapsed">
                            <Grid MinWidth="{Binding ViewportWidth,  ElementName=ImageScrollViewer}"
                                  MinHeight="{Binding ViewportHeight, ElementName=ImageScrollViewer}">
                                <Image x:Name="ViewerImage"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Cursor="Hand"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       MouseLeftButtonDown="OnImageMouseDown"
                                       MouseMove="OnImageMouseMove"
                                       MouseLeftButtonUp="OnImageMouseUp">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                                    </Image.LayoutTransform>
                                </Image>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Panel de detalles -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource SurfaceBrush}">
                    <StackPanel Margin="20,16,20,24">

                        <!-- Símbolo -->
                        <TextBlock Text="SÍMBOLO" Style="{StaticResource DetailLabel}" Margin="0,0,0,4" />
                        <Border Background="#1500D4FF" CornerRadius="6" Padding="12,8" HorizontalAlignment="Left">
                            <TextBlock x:Name="DetailSymbol"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}" />
                        </Border>

                        <!-- Estrategia -->
                        <TextBlock Text="ESTRATEGIA" Style="{StaticResource DetailLabel}" />
                        <TextBlock x:Name="DetailStrategy"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <!-- Calificación manual (estrellas) -->
                        <TextBlock Text="CALIFICACIÓN PERSONAL" Style="{StaticResource DetailLabel}" />
                        <StackPanel Orientation="Horizontal">
                            <ItemsControl x:Name="StarDisplay">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <TextBlock x:Name="ManualRatingText"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>

                        <!-- Promedio confluencias -->
                        <TextBlock x:Name="ConfluenceHeader"
                                   Text="CALIFICACIÓN CONFLUENCIAS" Style="{StaticResource DetailLabel}" />
                        <StackPanel x:Name="ConfluenceRatingPanel" Orientation="Horizontal" Margin="0,0,0,8">
                            <Border x:Name="ConfluenceBadge"
                                    CornerRadius="6" Padding="10,6">
                                <TextBlock x:Name="ConfluenceAvgText"
                                           FontSize="18" FontWeight="Bold" />
                            </Border>
                        </StackPanel>

                        <!-- Lista de confluencias -->
                        <ItemsControl x:Name="ConfluenceList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ConfluenceName}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="1"
                                                Background="#1500D4FF" CornerRadius="4"
                                                Padding="8,3" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding Rating}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{DynamicResource CyanGlowBrush}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Notas -->
                        <TextBlock x:Name="NotesHeader"
                                   Text="NOTAS" Style="{StaticResource DetailLabel}" />
                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12,10">
                            <TextBlock x:Name="NotesText"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="20" />
                        </Border>

                        <!-- Fecha -->
                        <TextBlock Text="FECHA" Style="{StaticResource DetailLabel}" />
                        <TextBlock x:Name="DateText"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}" />

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>
</Window>
