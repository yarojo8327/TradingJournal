<Window x:Class="Application.WPF.Views.Playbook.PlaybookFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Application.WPF.ViewModels.Playbook;assembly=Application.WPF.ViewModels"
        xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
        xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:PlaybookViewModel}"
        Title="{Binding FormTitle}"
        Width="1180" Height="720"
        MinWidth="960" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False">

    <Window.Resources>
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource CyanGlowBrush}" />
            <Setter Property="Margin"     Value="0,14,0,8" />
        </Style>

        <!-- Botón de zoom -->
        <Style x:Key="ZoomBtn" TargetType="Button">
            <Setter Property="Width"           Value="30" />
            <Setter Property="Height"          Value="30" />
            <Setter Property="Background"      Value="#20FFFFFF" />
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#35FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── BARRA DE TÍTULO ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseDown="OnTitleBarMouseDown">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="16" CornerRadius="1.5"
                                Background="{DynamicResource CyanGlowBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Mensajes inline en la barra de título -->
                    <Border Grid.Column="1" Margin="20,0"
                            Background="#1A00E676" BorderBrush="#00E676" BorderThickness="1"
                            CornerRadius="4" Padding="10,4"
                            Visibility="{Binding GeneralSuccess, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding GeneralSuccess}" FontSize="11"
                                   Foreground="#00E676" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Margin="20,0"
                            Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,4"
                            Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding GeneralError}" FontSize="11"
                                   Foreground="{DynamicResource AccentRedBrush}" VerticalAlignment="Center" />
                    </Border>

                    <Button Grid.Column="2" Command="{Binding CancelCommand}"
                            Width="36" Height="36" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="✕" FontSize="14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#20FF4444" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── CUERPO: LEFT (form) + RIGHT (imagen con zoom) ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.40*" MinWidth="380" />
                    <ColumnDefinition Width="0.60*" />
                </Grid.ColumnDefinitions>

                <!-- ─── COLUMNA IZQUIERDA — FORMULARIO ─── -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,16,18,20">
                        <StackPanel>

                            <!-- SÍMBOLO -->
                            <TextBlock Text="{loc:Tr Playbook_Section_Symbol}" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding Symbols}"
                                      Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                      Style="{DynamicResource FormComboBox}" />

                            <!-- ESTRATEGIA -->
                            <TextBlock Text="{loc:Tr Playbook_Section_Strategy}" Style="{StaticResource SectionLabel}" />
                            <ComboBox ItemsSource="{Binding FilterStrategies}"
                                      SelectedItem="{Binding SelectedStrategy}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding Title}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="{loc:Tr Playbook_NoStrategyItem}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- CONFLUENCIAS -->
                            <TextBlock Text="{loc:Tr Playbook_Section_Confluences}" Style="{StaticResource SectionLabel}" />
                            <Border Padding="0,2,0,8"
                                    Visibility="{Binding HasNoConfluences, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{loc:Tr Playbook_NoConfluencesHint}"
                                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <ItemsControl ItemsSource="{Binding ConfluenceItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6"
                                                Background="{DynamicResource SurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="10,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="78" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding ConfluenceName}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <ComboBox Grid.Column="2"
                                                          ItemsSource="{x:Static vm:PlaybookConfluenceItem.RatingValues}"
                                                          SelectedItem="{Binding Rating}"
                                                          Style="{DynamicResource FormComboBox}" Height="30">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" FontSize="12"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Promedio confluencias -->
                            <Border Margin="0,2,0,0"
                                    Background="{DynamicResource SurfaceElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12,10"
                                    Visibility="{Binding HasRatings, Converter={StaticResource BoolToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr Playbook_Section_AvgConfl}"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3" />
                                        <TextBlock Text="{Binding AverageRatingDisplay}"
                                                   FontSize="20" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#00E676" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsQualified}" Value="False">
                                                            <Setter Property="Foreground" Value="#FF9800" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="5" Padding="8,5" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1500E676" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsQualified}" Value="False">
                                                        <Setter Property="Background" Value="#15FF9800" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding QualityLabel}" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#00E676" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsQualified}" Value="False">
                                                            <Setter Property="Foreground" Value="#FF9800" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- CALIFICACIÓN PERSONAL (estrellas) -->
                            <TextBlock Text="{loc:Tr Playbook_Section_PersonalRating}" Style="{StaticResource SectionLabel}" />
                            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{loc:Tr Playbook_ManualRating}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Background="#1500D4FF"
                                                CornerRadius="4" Padding="8,3">
                                            <TextBlock Text="{Binding ManualRatingDisplay}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{DynamicResource CyanGlowBrush}" />
                                        </Border>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding StarItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SetManualRatingCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Value}"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Width="30" Height="30">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text"       Value="☆" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFilled}" Value="True">
                                                                        <Setter Property="Text"       Value="★" />
                                                                        <Setter Property="Foreground" Value="#FFD700" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- NOTAS -->
                            <TextBlock Text="{loc:Tr Playbook_Section_Notes}" Style="{StaticResource SectionLabel}" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Height="80" VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Tag="Contexto del mercado, aprendizajes, observaciones…" />

                            <!-- GUARDAR -->
                            <Button Command="{Binding SaveCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                    HorizontalAlignment="Stretch" Height="44" Margin="0,16,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Content" Value="{loc:Tr Playbook_SaveEntry}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Content" Value="{loc:Tr Playbook_SavingEntry}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ─── COLUMNA DERECHA — IMAGEN + ZOOM ─── -->
                <Grid Grid.Column="1" Background="{DynamicResource SurfaceElevatedBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />   <!-- Barra de herramientas -->
                        <RowDefinition Height="*" />      <!-- Área de imagen -->
                    </Grid.RowDefinitions>

                    <!-- Barra superior: botones seleccionar/eliminar + controles de zoom -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Seleccionar imagen -->
                            <Button Grid.Column="0"
                                    Click="OnBrowseImage"
                                    Style="{DynamicResource PrimaryButton}"
                                    Height="32" Padding="12,0" FontSize="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁 " VerticalAlignment="Center" FontSize="13" />
                                    <TextBlock Text="{loc:Tr Playbook_SelectImage}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Eliminar imagen (solo visible si hay imagen) -->
                            <Button Grid.Column="1"
                                    Command="{Binding RemoveImageCommand}"
                                    Style="{DynamicResource GhostButton}"
                                    Height="32" Padding="10,0" FontSize="12" Margin="8,0,0,0"
                                    Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{loc:Tr Playbook_RemoveImage}" VerticalAlignment="Center" />
                            </Button>

                            <!-- Controles de zoom (visibles solo con imagen cargada) -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                                <Button x:Name="BtnZoomOut" Style="{StaticResource ZoomBtn}"
                                        Click="OnZoomOut" ToolTip="{loc:Tr Playbook_ZoomOut}">
                                    <TextBlock Text="−" FontSize="16" FontWeight="Bold" />
                                </Button>
                                <Border Background="#15FFFFFF" CornerRadius="4"
                                        Padding="10,0" Margin="4,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="ZoomLabel"
                                               Text="100%"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Button x:Name="BtnZoomIn" Style="{StaticResource ZoomBtn}"
                                        Click="OnZoomIn" ToolTip="{loc:Tr Playbook_ZoomIn}">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold" />
                                </Button>
                                <Button Style="{StaticResource ZoomBtn}" Margin="4,0,0,0"
                                        Click="OnZoomReset" ToolTip="{loc:Tr Playbook_ResetZoom}">
                                    <TextBlock Text="⊙" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Área de imagen con zoom -->
                    <Grid Grid.Row="1">

                        <!-- Placeholder (sin imagen) -->
                        <Border Background="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🖼️" FontSize="56"
                                           HorizontalAlignment="Center" Margin="0,0,0,16" />
                                <TextBlock Text="{loc:Tr Playbook_NoImage}"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Tr Playbook_NoImageHint}"
                                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" />
                                <TextBlock Text="PNG · JPG · BMP · GIF · WEBP"
                                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.6" />
                            </StackPanel>
                        </Border>

                        <!-- ScrollViewer con imagen zoomeable — se adapta al contenedor -->
                        <ScrollViewer x:Name="ImageScrollViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      PanningMode="Both"
                                      PreviewMouseWheel="OnMouseWheel"
                                      Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                            <Grid MinWidth="{Binding ViewportWidth,  ElementName=ImageScrollViewer}"
                                  MinHeight="{Binding ViewportHeight, ElementName=ImageScrollViewer}">
                                <Image x:Name="PreviewImage"
                                       Source="{Binding ImagePreview}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="OnImageMouseDown"
                                       MouseMove="OnImageMouseMove"
                                       MouseLeftButtonUp="OnImageMouseUp"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                                    </Image.LayoutTransform>
                                </Image>
                            </Grid>
                        </ScrollViewer>

                    </Grid>
                </Grid>

            </Grid>

            <!-- Loading overlay -->
            <Border Grid.RowSpan="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"  Value="#CC0D1117" />
                        <Setter Property="Visibility"  Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="240" Height="3"
                                 Foreground="{DynamicResource CyanGlowBrush}"
                                 Background="{DynamicResource BorderBrush}" BorderThickness="0" />
                    <TextBlock Text="{loc:Tr Playbook_Saving}"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
