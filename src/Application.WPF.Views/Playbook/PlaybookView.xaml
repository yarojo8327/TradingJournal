<UserControl x:Class="Application.WPF.Views.Playbook.PlaybookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Playbook;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PlaybookViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter      x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter           x:Key="InverseBool" />
        <converters:StringToVisibilityConverter    x:Key="StringToVisibility" />
        <converters:ByteArrayToImageConverter      x:Key="BytesToImage" />

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="#12FFFFFF" />
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#25FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource CyanGlowBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón de acción pequeño en tarjeta -->
        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Margin="32,24,32,40">

                <!-- ═══ ENCABEZADO ═══ -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <Border Width="3" Height="22" CornerRadius="1.5"
                                    Background="{DynamicResource CyanGlowBrush}"
                                    Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="Playbook"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Registra tus trades más significativas para revisión y aprendizaje"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="13,0,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding NewEntryCommand}"
                            Height="36" Padding="16,0" FontSize="13"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+ Nuevo registro" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ═══ FILTROS ═══ -->
                <Border Style="{DynamicResource Card}" Margin="0,0,0,12" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.28*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="0.28*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="0.44*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Símbolo -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Símbolo"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,5" />
                            <ComboBox ItemsSource="{Binding FilterSymbolOptions}"
                                      Text="{Binding FilterSymbol, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <!-- Estrategia -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Estrategia"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,5" />
                            <ComboBox ItemsSource="{Binding FilterStrategies}"
                                      SelectedItem="{Binding FilterStrategy}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding Title}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="— Todas —" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Calificación personal — estrellas clicables -->
                        <StackPanel Grid.Column="4">
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Calificación personal"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <Border Grid.Column="2"
                                        Background="#15FFD700" CornerRadius="4"
                                        Padding="8,2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FilterRatingDisplay}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FFD700" />
                                </Border>
                            </Grid>
                            <!-- Estrellas de filtro -->
                            <ItemsControl ItemsSource="{Binding FilterStarItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SetFilterRatingCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Value}"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Width="32" Height="34">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#10FFD700" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock FontSize="19" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="☆" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFilled}" Value="True">
                                                                <Setter Property="Text"       Value="★" />
                                                                <Setter Property="Foreground" Value="#FFD700" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Botones Filtrar / Limpiar -->
                        <Button Grid.Column="6"
                                Content="Filtrar"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding ApplyFilterCommand}"
                                Height="34" Padding="20,0"
                                VerticalAlignment="Bottom" />
                        <Button Grid.Column="8"
                                Content="Limpiar"
                                Style="{DynamicResource GhostButton}"
                                Command="{Binding ClearFilterCommand}"
                                Height="34" Padding="14,0"
                                VerticalAlignment="Bottom" />
                    </Grid>
                </Border>

                <!-- Mensajes -->
                <Border Background="#1A00E676" BorderBrush="#00E676" BorderThickness="1"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                        Visibility="{Binding GeneralSuccess, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralSuccess}" FontSize="12"
                               Foreground="#00E676" TextWrapping="Wrap" />
                </Border>
                <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                        Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralError}" FontSize="12"
                               Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                </Border>

                <!-- ═══ LISTA DE REGISTROS ═══ -->
                <Border Style="{DynamicResource Card}" Padding="0">
                    <StackPanel>

                        <!-- Cabecera -->
                        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                CornerRadius="6,6,0,0" Padding="20,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="REGISTROS GUARDADOS"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource CyanGlowBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PageInfo}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Estado vacío -->
                        <Border Padding="24,48"
                                Visibility="{Binding HasNoEntries, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📖" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,14" />
                                <TextBlock Text="Tu playbook está vacío"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Guarda tus trades más significativas para analizarlas y aprender de ellas."
                                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Grid de tarjetas — 3 columnas -->
                        <ItemsControl ItemsSource="{Binding PagedEntries}" Margin="12,12,12,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6"
                                            Background="{DynamicResource SurfaceElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="10"
                                            Padding="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource CyanGlowBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="180" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Miniatura de imagen -->
                                            <Border Grid.Row="0" CornerRadius="10,10,0,0" ClipToBounds="True"
                                                    Background="#08FFFFFF">
                                                <Grid>
                                                    <!-- Placeholder (sin imagen) -->
                                                    <TextBlock Text="📊" FontSize="40"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Opacity="0.2">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Miniatura desde byte[] -->
                                                    <Image Source="{Binding ImageData, Converter={StaticResource BytesToImage}}"
                                                           Stretch="UniformToFill"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Grid>
                                            </Border>

                                            <!-- Info de la tarjeta -->
                                            <StackPanel Grid.Row="1" Margin="14,10,14,12">

                                                <!-- Fila: Símbolo + badges de rating -->
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Símbolo -->
                                                    <Border Grid.Column="0"
                                                            Background="#1500D4FF"
                                                            CornerRadius="4" Padding="7,3">
                                                        <TextBlock Text="{Binding Symbol}"
                                                                   FontSize="12" FontWeight="Bold"
                                                                   Foreground="{DynamicResource CyanGlowBrush}" />
                                                    </Border>

                                                    <!-- Badge confluencias -->
                                                    <Border Grid.Column="2"
                                                            CornerRadius="4" Padding="7,3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"  Value="#1500E676" />
                                                                <Setter Property="Visibility"  Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Rating}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="#00E676"
                                                                   Text="{Binding Rating, StringFormat='⚡ {0:F1}'}" />
                                                    </Border>

                                                    <!-- Badge estrellas -->
                                                    <Border Grid.Column="4"
                                                            CornerRadius="4" Padding="7,3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"  Value="#15FFD700" />
                                                                <Setter Property="Visibility"  Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ManualRating}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="#FFD700"
                                                                   Text="{Binding ManualRating, StringFormat='★ {0}'}" />
                                                    </Border>
                                                </Grid>

                                                <!-- Estrategia -->
                                                <TextBlock Text="{Binding Strategy.Title, FallbackValue='Sin estrategia'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource CyanGlowBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,4" />

                                                <!-- Notas (extracto) -->
                                                <TextBlock Text="{Binding Notes}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="32"
                                                           Margin="0,0,0,8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Fecha + acciones -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding CreatedAt, StringFormat={}{0:dd/MM/yy}}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <!-- Ver (abre visor flotante) -->
                                                        <Button Content="Ver"
                                                                Style="{StaticResource CardActionBtn}"
                                                                BorderBrush="#FFD700"
                                                                Foreground="#FFD700"
                                                                FontSize="10" Padding="6,3" Margin="0,0,4,0"
                                                                Command="{Binding DataContext.ViewEntryCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="Editar"
                                                                Style="{StaticResource CardActionBtn}"
                                                                BorderBrush="{DynamicResource CyanGlowBrush}"
                                                                Foreground="{DynamicResource CyanGlowBrush}"
                                                                FontSize="10" Padding="6,3" Margin="0,0,4,0"
                                                                Command="{Binding DataContext.EditEntryCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="✕"
                                                                Style="{StaticResource CardActionBtn}"
                                                                BorderBrush="{DynamicResource AccentRedBrush}"
                                                                Foreground="{DynamicResource AccentRedBrush}"
                                                                FontSize="10" Padding="6,3"
                                                                Command="{Binding DataContext.DeleteEntryCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Paginación -->
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                Padding="16,10" Margin="0,12,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoEntries}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Style="{StaticResource NavBtn}"
                                        Command="{Binding PreviousPageCommand}"
                                        IsEnabled="{Binding IsFirstPage, Converter={StaticResource InverseBool}}"
                                        Width="36" Height="28" Padding="0">
                                    <TextBlock Text="‹" FontSize="16" FontWeight="Bold"
                                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Button>
                                <TextBlock Grid.Column="1" Text="{Binding PageInfo}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource NavBtn}"
                                        Command="{Binding NextPageCommand}"
                                        IsEnabled="{Binding IsLastPage, Converter={StaticResource InverseBool}}"
                                        Width="36" Height="28" Padding="0">
                                    <TextBlock Text="›" FontSize="16" FontWeight="Bold"
                                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Button>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background"  Value="#CC0D1117" />
                    <Setter Property="Visibility"  Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="3"
                             Foreground="{DynamicResource CyanGlowBrush}"
                             Background="{DynamicResource BorderBrush}"
                             BorderThickness="0" />
                <TextBlock Text="Cargando playbook…"
                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
