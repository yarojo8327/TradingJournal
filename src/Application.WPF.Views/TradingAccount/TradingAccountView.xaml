<UserControl x:Class="Application.WPF.Views.TradingAccount.TradingAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.TradingAccount;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TradingAccountViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="40,32,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="540" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" MaxWidth="480" />
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════
                 COLUMNA IZQUIERDA — Datos de la cuenta
                 ═══════════════════════════════════════ -->
            <StackPanel Grid.Column="0">

                <!-- Encabezado -->
                <StackPanel Margin="0,0,0,28">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="3" Height="22" CornerRadius="1.5"
                                Background="{DynamicResource CyanGlowBrush}"
                                Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Registrar cuenta de trading" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="Editar cuenta de trading" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="Información de tu cuenta en el broker"
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="13,0,0,0" />
                </StackPanel>

                <!-- Broker -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Broker" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding Broker, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource FormTextBox}"
                             Tag="Ej: Interactive Brokers, Pepperstone…" />
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), RelativeSource={RelativeSource AncestorType=TextBox}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" FontSize="11"
                                           Foreground="{DynamicResource AccentRedBrush}" Margin="2,3,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Número de cuenta -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Número de cuenta" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource FormTextBox}"
                             Tag="Ej: 12345678" />
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), RelativeSource={RelativeSource AncestorType=TextBox}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" FontSize="11"
                                           Foreground="{DynamicResource AccentRedBrush}" Margin="2,3,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Tipo de cuenta -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Tipo de cuenta" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding AccountTypes}"
                              SelectedItem="{Binding SelectedAccountType}"
                              DisplayMemberPath="Display"
                              Height="40"
                              Background="{DynamicResource SurfaceElevatedBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              BorderThickness="1"
                              FontSize="13">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter Property="Padding"    Value="12,8" />
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), RelativeSource={RelativeSource AncestorType=ComboBox}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" FontSize="11"
                                           Foreground="{DynamicResource AccentRedBrush}" Margin="2,3,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Fecha de inicio -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Fecha de inicio de operación" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <DatePicker SelectedDate="{Binding StartDate}"
                                Height="40"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                FontSize="13" />
                </StackPanel>

            </StackPanel>

            <!-- ════════════════════════════════════
                 COLUMNA DERECHA — Datos financieros
                 ════════════════════════════════════ -->
            <StackPanel Grid.Column="2">

                <!-- Encabezado -->
                <StackPanel Margin="0,0,0,28">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="3" Height="22" CornerRadius="1.5"
                                Background="{DynamicResource PrimaryBrush}"
                                Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="Datos financieros"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Capital y condiciones de la cuenta"
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="13,0,0,0" />
                </StackPanel>

                <!-- Capital inicial -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Capital inicial" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding InitialCapitalText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource FormTextBox}"
                             Tag="Ej: 10000.00" />
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), RelativeSource={RelativeSource AncestorType=TextBox}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" FontSize="11"
                                           Foreground="{DynamicResource AccentRedBrush}" Margin="2,3,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Divisa base -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Divisa base" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding BaseCurrency, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource FormTextBox}"
                             Tag="Ej: USD, EUR, GBP" />
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), RelativeSource={RelativeSource AncestorType=TextBox}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" FontSize="11"
                                           Foreground="{DynamicResource AccentRedBrush}" Margin="2,3,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Apalancamiento -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Apalancamiento" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding Leverage, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource FormTextBox}"
                             Tag="Ej: 1:100" />
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), RelativeSource={RelativeSource AncestorType=TextBox}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" FontSize="11"
                                           Foreground="{DynamicResource AccentRedBrush}" Margin="2,3,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Resumen card (modo edición) -->
                <Border Style="{DynamicResource AccentCard}" Margin="0,8,0,20"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="Cuenta activa"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource CyanGlowBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding Broker, FallbackValue=—}" />
                            <Run Text=" · " Foreground="{DynamicResource TextMutedBrush}" />
                            <Run Text="{Binding AccountNumber, FallbackValue=—}" />
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0">
                            <Run Text="Capital: " />
                            <Run Text="{Binding InitialCapitalText, FallbackValue=0}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Run Text=" " />
                            <Run Text="{Binding BaseCurrency, FallbackValue=—}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Mensajes de estado -->
                <Border Background="#1A00E676" BorderBrush="#00E676" BorderThickness="1"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                        Visibility="{Binding GeneralSuccess, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralSuccess}" FontSize="12"
                               Foreground="#00E676" TextWrapping="Wrap" />
                </Border>
                <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,16"
                        Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding GeneralError}" FontSize="12"
                               Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                </Border>

                <!-- Botón guardar -->
                <Button Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Height="44" FontSize="14" FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Content" Value="Guardar cuenta" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Content" Value="Guardando…" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
