<Window x:Class="Application.WPF.Views.Journal.TradeDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
        xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Width="860" Height="640"
        MinWidth="700" MinHeight="480"
        ShowInTaskbar="False"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="9" />
            <Setter Property="FontWeight"  Value="Bold" />
            <Setter Property="Foreground"  Value="{DynamicResource CyanGlowBrush}" />
            <Setter Property="Margin"      Value="0,0,0,8" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Margin"     Value="0,0,0,2" />
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="13" />
            <Setter Property="Foreground"    Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping"  Value="Wrap" />
        </Style>
        <Style x:Key="FieldValueMuted" TargetType="TextBlock" BasedOn="{StaticResource FieldValue}">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize"   Value="12" />
        </Style>
    </Window.Resources>

    <!-- Marco exterior con sombra -->
    <Border Margin="16" CornerRadius="10"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Barra de título -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0"
                    Background="{DynamicResource SurfaceBrush}"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Margin="20,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="18" CornerRadius="1.5"
                                Background="{DynamicResource CyanGlowBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock x:Name="TitleText"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Badge símbolo -->
                    <Border Grid.Column="1" HorizontalAlignment="Left" Margin="12,0,0,0"
                            VerticalAlignment="Center" CornerRadius="4" Padding="8,3"
                            Background="#1500D4FF">
                        <TextBlock x:Name="SymbolBadge" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource CyanGlowBrush}" />
                    </Border>

                    <Button Grid.Column="2" Width="32" Height="32" VerticalAlignment="Center"
                            Click="OnClose">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="6" Background="Transparent">
                                    <TextBlock Text="✕" FontSize="13"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#1AFF4444" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Rectangle Grid.Row="1" Fill="{DynamicResource BorderBrush}" />

            <!-- Contenido -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <Grid Margin="24,20,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <!-- Columna izquierda: campos del trade -->
                    <StackPanel Grid.Column="0">

                        <!-- Identificación -->
                        <TextBlock Text="{loc:Tr Journal_Section_TradeData}" Style="{StaticResource SectionLabel}" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Tr Journal_Account}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="AccountText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Tr Journal_Strategy}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="StrategyText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{loc:Tr Journal_Direction}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="DirectionText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </Grid>

                        <!-- Timing -->
                        <TextBlock Text="{loc:Tr Journal_Section_Execution}" Style="{StaticResource SectionLabel}" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Tr Journal_EntryDate}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="EntryDateText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Tr Journal_ExitDate}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="ExitDateText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </Grid>

                        <!-- Precios -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Tr Journal_EntryPrice}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="EntryPriceText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Tr Journal_ExitPrice}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="ExitPriceText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{loc:Tr Journal_StopLoss}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="StopLossText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="{loc:Tr Journal_TakeProfit}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="TakeProfitText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="8">
                                <TextBlock Text="{loc:Tr Journal_PositionSize}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="PositionSizeText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

                        <!-- Resultado -->
                        <TextBlock Text="{loc:Tr Journal_Section_Result}" Style="{StaticResource SectionLabel}" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Tr Journal_Result}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="ResultText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Tr Journal_ProfitLoss}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="PnlText" Style="{StaticResource FieldValue}" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{loc:Tr Journal_RiskAmount}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="RiskText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="{loc:Tr Journal_RR}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="RrText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

                        <!-- Contexto -->
                        <TextBlock Text="{loc:Tr Journal_Section_Context}" Style="{StaticResource SectionLabel}" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Tr Journal_Session}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="SessionText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Tr Journal_Timeframe}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="TimeframeText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{loc:Tr Journal_TradingType}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="TradingTypeText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

                        <!-- Psicología -->
                        <TextBlock Text="{loc:Tr Journal_Section_Psychology}" Style="{StaticResource SectionLabel}" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Tr Journal_EmotionalState}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="EmotionalStateText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Tr Journal_MistakeType}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="MistakeTypeText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{loc:Tr Journal_Rating}" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="RatingText" Style="{StaticResource FieldValue}" />
                            </StackPanel>
                        </Grid>

                        <!-- Notas -->
                        <StackPanel Margin="0,0,0,8"
                                    x:Name="NotesPanel" Visibility="Collapsed">
                            <TextBlock Text="{loc:Tr Journal_Notes}" Style="{StaticResource FieldLabel}" />
                            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="12,10">
                                <TextBlock x:Name="NotesText" Style="{StaticResource FieldValue}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>

                        <!-- URL gráfico -->
                        <StackPanel x:Name="UrlPanel" Visibility="Collapsed" Margin="0,0,0,0">
                            <TextBlock Text="{loc:Tr Journal_ScreenshotUrl}" Style="{StaticResource FieldLabel}" />
                            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="10,7">
                                <TextBlock x:Name="UrlText"
                                           FontSize="11" Foreground="{DynamicResource CyanGlowBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="OnOpenUrl" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Columna derecha: imagen -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{loc:Tr Journal_Detail_Image}" Style="{StaticResource SectionLabel}" />

                        <!-- Preview de imagen si es URL local o de trading view embebida -->
                        <Border x:Name="ImageContainer"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                MinHeight="180" Visibility="Collapsed">
                            <Image x:Name="TradeImage" Stretch="Uniform"
                                   MaxHeight="400" Margin="4" />
                        </Border>

                        <!-- Placeholder sin imagen -->
                        <Border x:Name="NoImageBorder"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Height="180">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="32" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Tr Journal_NoImage}" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Botón abrir URL -->
                        <Button x:Name="OpenUrlBtn"
                                Style="{DynamicResource PrimaryButton}"
                                Height="34" Margin="0,10,0,0"
                                Padding="12,0" FontSize="12"
                                Visibility="Collapsed"
                                Click="OnOpenUrl">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Tr Journal_OpenChart}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{DynamicResource SecondaryButton}"
                            Height="36" Padding="20,0" FontSize="13"
                            Click="OnClose">
                        <TextBlock Text="{loc:Tr Common_Close}" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
