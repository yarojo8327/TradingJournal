<UserControl x:Class="Application.WPF.Views.Journal.TradeJournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Journal;assembly=Application.WPF.ViewModels"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TradeJournalViewModel}"
             Background="{DynamicResource BackgroundBrush}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter          x:Key="StringToVisibility" />
        <converters:BoolToVisibilityConverter            x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter                 x:Key="InverseBool" />
        <converters:TradingSessionDisplayConverter       x:Key="SessionDisplay" />
        <converters:TradePctConverter                    x:Key="TradePct" />

        <!-- Cabecera de tabla -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize"          Value="9" />
            <Setter Property="FontWeight"        Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin"            Value="6,0" />
        </Style>

        <!-- Celda de tabla -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin"            Value="6,0" />
            <Setter Property="TextTrimming"      Value="CharacterEllipsis" />
        </Style>

        <!-- Etiqueta de sección del formulario -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="9" />
            <Setter Property="FontWeight"  Value="Bold" />
            <Setter Property="Foreground"  Value="{DynamicResource CyanGlowBrush}" />
            <Setter Property="Margin"      Value="0,0,0,10" />
        </Style>

        <!-- Etiqueta de campo -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin"     Value="0,0,0,5" />
        </Style>

        <!-- Botón pequeño de acción en tabla -->
        <Style x:Key="SmallActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="7,3" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Etiqueta KPI (izquierda) -->
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin"     Value="0,2,8,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Valor KPI (derecha) -->
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin"     Value="0,2,0,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <!-- Botón link (texto subrayado) -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="Txt"
                                   Text="{TemplateBinding Content}"
                                   FontSize="12"
                                   Foreground="{DynamicResource CyanGlowBrush}"
                                   TextDecorations="Underline"
                                   VerticalAlignment="Center" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Txt" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="32,24,32,40">

            <!-- ═══ ENCABEZADO ═══ -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <Border Width="3" Height="22" CornerRadius="1.5"
                                Background="{DynamicResource CyanGlowBrush}"
                                Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr Journal_Header}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{loc:Tr Journal_Subtitle}"
                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="13,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">

                    <!-- Importar MT5 Excel -->
                    <Button Style="{DynamicResource GhostButton}"
                            Command="{Binding ImportFromExcelCommand}"
                            Height="36" Padding="12,0" FontSize="12" Margin="0,0,8,0"
                            ToolTip="{loc:Tr Journal_ImportMt5Tooltip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource CyanGlowBrush}" />
                            <TextBlock Text="{loc:Tr Journal_ImportMt5_Label}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Exportar Excel -->
                    <Button Style="{DynamicResource GhostButton}"
                            Command="{Binding ExportToExcelCommand}"
                            Height="36" Padding="12,0" FontSize="12" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{loc:Tr Journal_ExportExcel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Nuevo Trade -->
                    <Button Style="{DynamicResource PrimaryButton}"
                            Command="{Binding NewTradeCommand}"
                            Height="36" Padding="16,0" FontSize="13">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Tr Journal_NewTrade}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Mensajes -->
            <Border Background="#1A00E676" BorderBrush="#00E676" BorderThickness="1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,10"
                    Visibility="{Binding GeneralSuccess, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding GeneralSuccess}" FontSize="12"
                           Foreground="#00E676" TextWrapping="Wrap" />
            </Border>
            <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,10"
                    Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding GeneralError}" FontSize="12"
                           Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
            </Border>

            <!-- ═══ FILTROS ═══ -->
            <Border Style="{DynamicResource Card}" Margin="0,0,0,6" Padding="16,14,16,12">
                <StackPanel>

                    <!-- Fila 1: Cuenta | Símbolo | Resultado | Estrategia -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Cuenta -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_Filter_Account}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding FilterAccounts}"
                                      SelectedItem="{Binding FilterAccount}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding Broker}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="{loc:Tr Common_AllAccounts}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Símbolo -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_Filter_Symbol}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding FilterSymbols}"
                                      Text="{Binding FilterSymbol, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      StaysOpenOnEdit="True"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <!-- Resultado -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_Filter_Result}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding FilterResults}"
                                      SelectedItem="{Binding FilterResult}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding Display}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="{loc:Tr Common_All}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Estrategia -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_Filter_Strategy}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding FilterStrategies}"
                                      SelectedItem="{Binding FilterStrategy}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding Title}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="{loc:Tr Common_AllStrategies}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Fila 2: Cal. mínima | Cal. máxima | (flex) | Filtrar | Limpiar -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_Filter_RatingMin}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding RatingOptions}"
                                      SelectedItem="{Binding FilterRatingMin}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="{loc:Tr Common_NoMin}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_Filter_RatingMax}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding RatingOptions}"
                                      SelectedItem="{Binding FilterRatingMax}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="{loc:Tr Common_NoMax}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- spacer -->
                        <Border Grid.Column="3" />

                        <Button Grid.Column="4" Content="{loc:Tr Journal_Filter_Apply}"
                                Style="{DynamicResource PrimaryButton}"
                                Command="{Binding ApplyFilterCommand}"
                                Height="34" Padding="20,0" VerticalAlignment="Bottom" />
                        <Button Grid.Column="6" Content="{loc:Tr Journal_Filter_Clear}"
                                Style="{DynamicResource GhostButton}"
                                Command="{Binding ClearFilterCommand}"
                                Height="34" Padding="14,0" VerticalAlignment="Bottom" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ RESUMEN DE CUENTA(S) ═══ -->
            <Border Style="{DynamicResource Card}" Margin="0,6,0,0" Padding="16,14,16,12"
                    Visibility="{Binding HasAccountSummaries, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr Journal_Section_AccountSummary}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource CyanGlowBrush}"
                               Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding AccountSummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="170" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="Auto" MinWidth="170" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="Auto" MinWidth="220" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="Auto" MinWidth="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Nombre de la cuenta -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Tr Journal_Col_AccountName}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,0,0,3" />
                                        <TextBlock Text="{Binding AccountName}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>

                                    <!-- Capital inicial -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{loc:Tr Journal_Col_InitialCapital}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,0,0,3" />
                                        <TextBlock Text="{Binding InitialCapitalDisplay}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>

                                    <!-- Ganancia / Pérdida -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{loc:Tr Journal_Col_GainLoss}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,0,0,3" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TotalPLDisplay}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#00E676" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1500E676" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                                                <Setter Property="Background" Value="#1AFF5555" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding PctChangeDisplay}"
                                                           FontSize="12" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#00E676" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                                                    <Setter Property="Foreground" Value="#FF5555" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Capital actual -->
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="{loc:Tr Journal_Col_CurrentCapital}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,0,0,3" />
                                        <TextBlock Text="{Binding CurrentCapitalDisplay}"
                                                   FontSize="14" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#00E676" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                                            <Setter Property="Foreground" Value="#FF5555" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ═══ PANEL DE ESTADÍSTICAS ═══ -->
            <Border x:Name="StatsBorder"
                    Style="{DynamicResource Card}" Margin="0,6,0,0" Padding="16,14,16,14"
                    Visibility="{Binding HasStats, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="0.75*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="170" />
                    </Grid.RowDefinitions>

                    <!-- Título -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Tr Journal_Section_Stats}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource CyanGlowBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Tr Journal_Section_EquityCurve}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{loc:Tr Journal_Section_PnlPerTrade}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}" />

                    <!-- ── Columna izquierda: KPI + Pie ─────────────────────────── -->
                    <Grid Grid.Row="2" Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="130" />
                        </Grid.RowDefinitions>

                        <!-- KPI table -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row styles defined inline via style triggers -->
                            <TextBlock Grid.Row="0" Grid.Column="0"  Text="{loc:Tr Journal_Stats_InitialCapital}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"  Text="{Binding StatsInitialCapital}" Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="1" Grid.Column="0"  Text="{loc:Tr Journal_Stats_TotalOps}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"  Text="{Binding StatsTotalOps}" Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="2" Grid.Column="0"  Text="{loc:Tr Journal_Stats_Won}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="2" Grid.Column="1"  Text="{Binding StatsWon}"      Foreground="#00E676" Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="3" Grid.Column="0"  Text="{loc:Tr Journal_Stats_Lost}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="3" Grid.Column="1"  Text="{Binding StatsLost}"     Foreground="{DynamicResource AccentRedBrush}" Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="4" Grid.Column="0"  Text="{loc:Tr Journal_Stats_WinRate}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="4" Grid.Column="1"  Text="{Binding StatsWinRate}"  Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="5" Grid.Column="0"  Text="{loc:Tr Journal_Stats_NetPnl}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="5" Grid.Column="1"  Text="{Binding StatsNetPnl}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource KpiValue}">
                                        <Setter Property="Foreground" Value="#00E676" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatsNetPnlPositive}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Grid.Row="6" Grid.Column="0"  Text="{loc:Tr Journal_Stats_BestTrade}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="6" Grid.Column="1"  Text="{Binding StatsBestTrade}"  Foreground="#00E676" Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="7" Grid.Column="0"  Text="{loc:Tr Journal_Stats_WorstTrade}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="7" Grid.Column="1"  Text="{Binding StatsWorstTrade}" Foreground="{DynamicResource AccentRedBrush}" Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="8" Grid.Column="0"  Text="{loc:Tr Journal_Stats_AvgPnl}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="8" Grid.Column="1"  Text="{Binding StatsAvgPnl}"   Style="{StaticResource KpiValue}" />

                            <TextBlock Grid.Row="9" Grid.Column="0"  Text="{loc:Tr Journal_Stats_TotalCapital}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="9" Grid.Column="1"  Text="{Binding StatsTotal}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource KpiValue}">
                                        <Setter Property="Foreground" Value="#00E676" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatsGainPositive}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="{loc:Tr Journal_Stats_GainPct}" Style="{StaticResource KpiLabel}" />
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding StatsGainPct}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource KpiValue}">
                                        <Setter Property="Foreground" Value="#00E676" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatsGainPositive}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Pie chart canvas -->
                        <Canvas x:Name="PieCanvas" Grid.Row="2"
                                SizeChanged="PieCanvas_SizeChanged" />
                    </Grid>

                    <!-- ── Equity Curve canvas ─────────────────────────────────── -->
                    <Canvas x:Name="StatsEquityCanvas"
                            Grid.Row="2" Grid.Column="2"
                            SizeChanged="StatsEquityCanvas_SizeChanged" />

                    <!-- ── P&L per trade bar chart canvas ──────────────────────── -->
                    <Canvas x:Name="PnlBarsCanvas"
                            Grid.Row="2" Grid.Column="4"
                            SizeChanged="PnlBarsCanvas_SizeChanged" />
                </Grid>
            </Border>

            <!-- ═══ TABLA DE TRADES ═══ -->
            <Border Style="{DynamicResource Card}" Margin="0,6,0,20" Padding="0">
                <Grid>
                    <StackPanel>

                    <!-- Cabecera -->
                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                            CornerRadius="6,6,0,0" Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />   <!-- 0  Fecha -->
                                <ColumnDefinition Width="68" />   <!-- 1  Símbolo -->
                                <ColumnDefinition Width="42" />   <!-- 2  Dir -->
                                <ColumnDefinition Width="88" />   <!-- 3  Cuenta -->
                                <ColumnDefinition Width="85" />   <!-- 4  Estrategia -->
                                <ColumnDefinition Width="70" />   <!-- 5  Entrada -->
                                <ColumnDefinition Width="70" />   <!-- 6  Salida -->
                                <ColumnDefinition Width="58" />   <!-- 7  SL -->
                                <ColumnDefinition Width="58" />   <!-- 8  TP -->
                                <ColumnDefinition Width="46" />   <!-- 9  Lotes -->
                                <ColumnDefinition Width="68" />   <!-- 10 P&L -->
                                <ColumnDefinition Width="60" />   <!-- 11 % Cap -->
                                <ColumnDefinition Width="42" />   <!-- 12 R:R -->
                                <ColumnDefinition Width="68" />   <!-- 13 Resultado -->
                                <ColumnDefinition Width="65" />   <!-- 14 Sesión -->
                                <ColumnDefinition Width="40" />   <!-- 15 Cal -->
                                <ColumnDefinition Width="*" />    <!-- 16 flex -->
                                <ColumnDefinition Width="172" />  <!-- 17 Acciones -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"  Text="{loc:Tr Journal_Col_Date}"      Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="1"  Text="{loc:Tr Journal_Col_Symbol}"    Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="2"  Text="{loc:Tr Journal_Col_Direction}" Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="3"  Text="{loc:Tr Journal_Col_Account}"   Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="4"  Text="{loc:Tr Journal_Col_Strategy}"  Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="5"  Text="{loc:Tr Journal_Col_Entry}"     Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="6"  Text="{loc:Tr Journal_Col_Exit}"      Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="7"  Text="{loc:Tr Journal_Col_SL}"        Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="8"  Text="{loc:Tr Journal_Col_TP}"        Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="9"  Text="{loc:Tr Journal_Col_Lots}"      Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="10" Text="{loc:Tr Journal_Col_PL}"        Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="11" Text="{loc:Tr Journal_Col_CapPct}"    Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="12" Text="{loc:Tr Journal_Col_RR}"        Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="13" Text="{loc:Tr Journal_Col_Result}"    Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="14" Text="{loc:Tr Journal_Col_Session}"   Style="{StaticResource ColHeader}" />
                            <TextBlock Grid.Column="15" Text="{loc:Tr Journal_Col_Rating}"    Style="{StaticResource ColHeader}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="17" Text="{loc:Tr Journal_Col_Actions}"   Style="{StaticResource ColHeader}" />
                        </Grid>
                    </Border>

                    <!-- Filas -->
                    <ItemsControl ItemsSource="{Binding PagedTrades}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,1,0,0" Padding="0,11">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="68" />
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="85" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="68" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="68" />
                                            <ColumnDefinition Width="65" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="172" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Fecha -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding EntryDate, StringFormat={}{0:dd/MM/yy HH:mm}}"
                                                   Style="{StaticResource CellText}" FontSize="11" />

                                        <!-- Símbolo -->
                                        <TextBlock Grid.Column="1" Text="{Binding Symbol}"
                                                   Style="{StaticResource CellText}" FontWeight="SemiBold" />

                                        <!-- Dirección -->
                                        <Border Grid.Column="2" CornerRadius="3" Padding="5,2"
                                                VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1500E676" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="Short">
                                                            <Setter Property="Background" Value="#1AFF4444" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="▲ L" />
                                                        <Setter Property="Foreground" Value="#00E676" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Direction}" Value="Short">
                                                                <Setter Property="Text"       Value="▼ S" />
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Cuenta -->
                                        <TextBlock Grid.Column="3" Text="{Binding Account.Broker}"
                                                   Style="{StaticResource CellText}" FontSize="11" />

                                        <!-- Estrategia -->
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding Strategy.Title, FallbackValue='—'}"
                                                   Style="{StaticResource CellText}" FontSize="11" />

                                        <!-- Precios -->
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding EntryPrice, StringFormat={}{0:G}}"
                                                   Style="{StaticResource CellText}" FontSize="11" />
                                        <TextBlock Grid.Column="6"
                                                   Text="{Binding ExitPrice, StringFormat={}{0:G}, FallbackValue='—'}"
                                                   Style="{StaticResource CellText}" FontSize="11" />
                                        <TextBlock Grid.Column="7"
                                                   Text="{Binding StopLoss, StringFormat={}{0:G}, FallbackValue='—'}"
                                                   Style="{StaticResource CellText}" FontSize="11" />
                                        <TextBlock Grid.Column="8"
                                                   Text="{Binding TakeProfit, StringFormat={}{0:G}, FallbackValue='—'}"
                                                   Style="{StaticResource CellText}" FontSize="11" />
                                        <TextBlock Grid.Column="9"
                                                   Text="{Binding PositionSizeLots, StringFormat={}{0:G}, FallbackValue='—'}"
                                                   Style="{StaticResource CellText}" FontSize="11" />

                                        <!-- P&L con color dinámico -->
                                        <TextBlock Grid.Column="10"
                                                   Text="{Binding ProfitLoss, StringFormat={}{0:+#,##0.00;-#,##0.00;0}, FallbackValue='—'}"
                                                   FontSize="11" FontWeight="SemiBold" Margin="6,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Result}" Value="Profit">
                                                            <Setter Property="Foreground" Value="#00E676" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Result}" Value="Loss">
                                                            <Setter Property="Foreground" Value="#FF5555" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- % Cap. -->
                                        <TextBlock Grid.Column="11"
                                                   Text="{Binding Converter={StaticResource TradePct}}"
                                                   FontSize="11" FontWeight="SemiBold" Margin="6,0"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Result}" Value="Profit">
                                                            <Setter Property="Foreground" Value="#00E676" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Result}" Value="Loss">
                                                            <Setter Property="Foreground" Value="#FF5555" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- R:R -->
                                        <TextBlock Grid.Column="12"
                                                   Text="{Binding RiskRewardRatio, StringFormat={}{0:G}, FallbackValue='—'}"
                                                   Style="{StaticResource CellText}" FontSize="11" />

                                        <!-- Badge Resultado -->
                                        <Border Grid.Column="13" CornerRadius="4" Padding="7,2"
                                                VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1500D4FF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Result}" Value="Profit">
                                                            <Setter Property="Background" Value="#1500E676" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Result}" Value="Loss">
                                                            <Setter Property="Background" Value="#1AFF5555" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Result}" Value="BreakEven">
                                                            <Setter Property="Background" Value="#15FF9800" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="Open" />
                                                        <Setter Property="Foreground" Value="{DynamicResource CyanGlowBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Result}" Value="Profit">
                                                                <Setter Property="Text"       Value="Profit" />
                                                                <Setter Property="Foreground" Value="#00E676" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Result}" Value="Loss">
                                                                <Setter Property="Text"       Value="Loss" />
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Result}" Value="BreakEven">
                                                                <Setter Property="Text"       Value="BE" />
                                                                <Setter Property="Foreground" Value="#FF9800" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Sesión (localizada) -->
                                        <TextBlock Grid.Column="14"
                                                   Text="{Binding Session, Converter={StaticResource SessionDisplay}}"
                                                   Style="{StaticResource CellText}" FontSize="11" />

                                        <!-- Rating badge -->
                                        <Border Grid.Column="15"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                                CornerRadius="4" Width="32" Height="22">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"  Value="#1500D4FF" />
                                                    <Setter Property="Visibility"  Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Rating}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Rating}"
                                                       FontSize="11" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource CyanGlowBrush}" />
                                                        <Style.Triggers>
                                                            <!-- Verde para 8-10 -->
                                                            <DataTrigger Binding="{Binding Rating}" Value="8">
                                                                <Setter Property="Foreground" Value="#00E676" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Rating}" Value="9">
                                                                <Setter Property="Foreground" Value="#00E676" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Rating}" Value="10">
                                                                <Setter Property="Foreground" Value="#00E676" />
                                                            </DataTrigger>
                                                            <!-- Rojo para 1-4 -->
                                                            <DataTrigger Binding="{Binding Rating}" Value="1">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Rating}" Value="2">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Rating}" Value="3">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Rating}" Value="4">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Acciones: ↗ Gráfico | Editar | Eliminar -->
                                        <StackPanel Grid.Column="17" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="4,0,0,0">

                                            <!-- Abrir gráfico (solo si hay URL) -->
                                            <Button ToolTip="{loc:Tr Journal_OpenChart}"
                                                    Command="{Binding DataContext.OpenScreenshotCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding ScreenshotUrl}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SmallActionBtn}">
                                                        <Setter Property="Visibility"   Value="Collapsed" />
                                                        <Setter Property="BorderBrush"  Value="#44FFFFFF" />
                                                        <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}" />
                                                        <Setter Property="Margin"       Value="0,0,5,0" />
                                                        <Setter Property="Padding"      Value="5,3" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ScreenshotUrl,
                                                                         Converter={StaticResource StringToVisibility}}"
                                                                         Value="Visible">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12" VerticalAlignment="Center" />
                                            </Button>

                                            <!-- Ver detalle -->
                                            <Button Style="{StaticResource SmallActionBtn}"
                                                    BorderBrush="{DynamicResource TextMutedBrush}"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    ToolTip="{loc:Tr Journal_View}"
                                                    Margin="0,0,5,0" Padding="7,3"
                                                    Command="{Binding DataContext.ViewTradeCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8FF;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                    <TextBlock Text="{loc:Tr Journal_View}" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>

                                            <!-- Editar -->
                                            <Button Style="{StaticResource SmallActionBtn}"
                                                    BorderBrush="{DynamicResource CyanGlowBrush}"
                                                    Foreground="{DynamicResource CyanGlowBrush}"
                                                    ToolTip="{loc:Tr Journal_Edit}"
                                                    Margin="0,0,5,0" Padding="7,3"
                                                    Command="{Binding DataContext.EditTradeCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                    <TextBlock Text="{loc:Tr Journal_Edit}" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>

                                            <!-- Eliminar -->
                                            <Button Style="{StaticResource SmallActionBtn}"
                                                    BorderBrush="{DynamicResource AccentRedBrush}"
                                                    Foreground="{DynamicResource AccentRedBrush}"
                                                    ToolTip="{loc:Tr Journal_Delete}"
                                                    Padding="7,3"
                                                    Command="{Binding DataContext.DeleteTradeCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                    <TextBlock Text="{loc:Tr Journal_Delete}" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Estado vacío -->
                    <Border Padding="24,32"
                            Visibility="{Binding HasNoTrades, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10" />
                            <TextBlock Text="{loc:Tr Journal_Empty}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{loc:Tr Journal_EmptyHint}"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ── Paginación ── -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="16,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoTrades}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Anterior -->
                            <Button Grid.Column="0" Content="{loc:Tr Journal_Prev}"
                                    Command="{Binding PreviousPageCommand}"
                                    Height="30" Padding="12,0" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFirstPage}" Value="True">
                                                <Setter Property="Opacity"   Value="0.35" />
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Info de página -->
                            <TextBlock Grid.Column="1" Text="{Binding PageInfo}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />

                            <!-- Siguiente -->
                            <Button Grid.Column="2" Content="{loc:Tr Journal_Next}"
                                    Command="{Binding NextPageCommand}"
                                    Height="30" Padding="12,0" FontSize="12">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="Opacity"   Value="1" />
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLastPage}" Value="True">
                                                <Setter Property="Opacity"   Value="0.35" />
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    </StackPanel>

                    <!-- Loading overlay -->
                    <Border CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"  Value="#CC0D1117" />
                                <Setter Property="Visibility"  Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60">
                            <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                                         Foreground="{DynamicResource CyanGlowBrush}"
                                         Background="{DynamicResource BorderBrush}"
                                         BorderThickness="0" />
                            <TextBlock Text="{loc:Tr Journal_Loading}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- El formulario se abre en TradeFormWindow (ventana flotante modal).
                 Ver TradeJournalView.xaml.cs → OnVmPropertyChanged -->
            <Border Visibility="Collapsed">
                <StackPanel>

                    <!-- Título del formulario -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" Height="20" CornerRadius="1.5"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding FormSectionTitle}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="{loc:Tr Journal_Cancel}"
                                Style="{DynamicResource GhostButton}"
                                Command="{Binding CancelCommand}"
                                FontSize="12" Padding="10,6" />
                    </Grid>

                    <!-- ── SECCIÓN 1: DATOS DEL TRADE ── -->
                    <TextBlock Text="DATOS DEL TRADE" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Cuenta -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_Account}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <!-- Estrategia -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_Strategy}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Strategies}"
                                      SelectedItem="{Binding SelectedStrategy}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <!-- Símbolo con autocomplete -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_Symbol}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Symbols}"
                                      Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      StaysOpenOnEdit="True"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <!-- Dirección -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_Direction}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Directions}"
                                      SelectedItem="{Binding SelectedDirection}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                    </Grid>

                    <!-- Fechas y horas -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_EntryDate}" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding EntryDate}"
                                        Style="{DynamicResource FormDatePicker}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_EntryTime}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding EntryTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="HH:mm" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_ExitDate}" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding ExitDate}"
                                        Style="{DynamicResource FormDatePicker}" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_ExitTime}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ExitTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="HH:mm" />
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,18" />

                    <!-- ── SECCIÓN 2: EJECUCIÓN ── -->
                    <TextBlock Text="EJECUCIÓN" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_EntryPrice}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding EntryPriceText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_ExitPrice}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ExitPriceText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_StopLoss}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding StopLossText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_TakeProfit}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding TakeProfitText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="{loc:Tr Journal_PositionSize}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding PositionSizeText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.01" />
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,18" />

                    <!-- ── SECCIÓN 3: RESULTADO ── -->
                    <TextBlock Text="RESULTADO" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" MaxWidth="160" />
                        </Grid.ColumnDefinitions>

                        <!-- Resultado auto-calculado -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="{loc:Tr Journal_Result}"
                                           Style="{StaticResource FieldLabel}" Margin="0" />
                                <Border Background="#0F00D4FF" CornerRadius="3"
                                        Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="auto" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource CyanGlowBrush}" />
                                </Border>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding Results}"
                                      SelectedItem="{Binding SelectedResult}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_ProfitLoss}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ProfitLossText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="+120.50" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_RiskAmount}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding RiskAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="100.00" />
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_RR}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding RrText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="2.5" />
                        </StackPanel>

                        <!-- Calificación del trade -->
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="{loc:Tr Journal_Rating}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding RatingOptions}"
                                      SelectedItem="{Binding SelectedRating}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="{Binding}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                <Setter Property="Text"       Value="— Sin calificar —" />
                                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="8">
                                                                <Setter Property="Foreground" Value="#00E676" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="9">
                                                                <Setter Property="Foreground" Value="#00E676" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="10">
                                                                <Setter Property="Foreground" Value="#00E676" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="1">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="2">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="3">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="4">
                                                                <Setter Property="Foreground" Value="#FF5555" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,18" />

                    <!-- ── SECCIÓN 4: CONTEXTO ── -->
                    <TextBlock Text="CONTEXTO DE MERCADO" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="320" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" MaxWidth="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_Session}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Sessions}"
                                      SelectedItem="{Binding SelectedSession}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_Timeframe}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Timeframes}"
                                      Text="{Binding SelectedTimeframe, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,18" />

                    <!-- ── SECCIÓN 5: PSICOLOGÍA, GRÁFICO Y NOTAS ── -->
                    <TextBlock Text="PSICOLOGÍA, GRÁFICO Y NOTAS" Style="{StaticResource SectionLabel}" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <!-- Psicología -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="{loc:Tr Journal_EmotionalState}" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding EmotionalStates}"
                                          SelectedItem="{Binding SelectedEmotionalState}"
                                          Style="{DynamicResource FormComboBox}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Journal_MistakeType}" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding MistakeTypes}"
                                          SelectedItem="{Binding SelectedMistakeType}"
                                          Style="{DynamicResource FormComboBox}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- URL del gráfico + botón abrir -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_ScreenshotUrl}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ScreenshotUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="https://www.tradingview.com/chart/..." />

                            <!-- Botón y vista previa de la URL -->
                            <Border Margin="0,8,0,0"
                                    Visibility="{Binding ScreenshotUrl, Converter={StaticResource StringToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{DynamicResource PrimaryButton}"
                                            Height="34" Padding="14,0" FontSize="12"
                                            Command="{Binding OpenScreenshotCommand}"
                                            CommandParameter="{Binding ScreenshotUrl}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊" FontSize="13" Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Abrir gráfico" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SurfaceElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8">
                                        <TextBlock Text="{Binding ScreenshotUrl}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource CyanGlowBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding ScreenshotUrl}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Notas -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_Notes}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="100"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Tag="Observaciones, aprendizajes, contexto del mercado…" />
                        </StackPanel>
                    </Grid>

                    <!-- Botón guardar -->
                    <Button Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Height="44" Margin="0,14,0,0"
                            HorizontalAlignment="Right" MinWidth="180">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Content" Value="{loc:Tr Journal_Save}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Content" Value="{loc:Tr Journal_Saving}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
