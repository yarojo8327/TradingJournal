<Window x:Class="Application.WPF.Views.Journal.TradeFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Application.WPF.ViewModels.Journal;assembly=Application.WPF.ViewModels"
        xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
        xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Width="1020" Height="700"
        MinWidth="860" MinHeight="560"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance Type=vm:TradeJournalViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
        <converters:BoolToVisibilityConverter   x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter        x:Key="InverseBool" />

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="9" />
            <Setter Property="FontWeight"  Value="Bold" />
            <Setter Property="Foreground"  Value="{DynamicResource CyanGlowBrush}" />
            <Setter Property="Margin"      Value="0,0,0,10" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin"     Value="0,0,0,5" />
        </Style>
    </Window.Resources>

    <!-- Marco exterior con sombra -->
    <Border Margin="16" CornerRadius="10"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />   <!-- Title bar -->
                <RowDefinition Height="1" />    <!-- Separator -->
                <RowDefinition Height="*" />    <!-- Content -->
                <RowDefinition Height="Auto" /> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ── Barra de título (arrastrable) ── -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0"
                    Background="{DynamicResource SurfaceBrush}"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Margin="20,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Ícono + título -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="18" CornerRadius="1.5"
                                Background="{DynamicResource CyanGlowBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="{Binding FormSectionTitle}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Badge modo edición -->
                    <Border Grid.Column="1" HorizontalAlignment="Left" Margin="12,0,0,0"
                            VerticalAlignment="Center" CornerRadius="4" Padding="8,3"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                        <Border.Background>
                            <SolidColorBrush Color="#FF9800" Opacity="0.15" />
                        </Border.Background>
                        <TextBlock Text="EDICIÓN" FontSize="9" FontWeight="Bold"
                                   Foreground="#FF9800" />
                    </Border>

                    <!-- Botón cerrar -->
                    <Button Grid.Column="2" Width="32" Height="32"
                            VerticalAlignment="Center"
                            Command="{Binding CancelCommand}"
                            ToolTip="Cerrar">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="6" Background="Transparent">
                                    <TextBlock Text="✕" FontSize="13"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#1AFF4444" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Separador -->
            <Rectangle Grid.Row="1" Fill="{DynamicResource BorderBrush}" />

            <!-- ── Contenido del formulario ── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Background="Transparent">
                <StackPanel Margin="24,20,24,16">

                    <!-- Mensaje de error -->
                    <Border Background="#1AFF4444" BorderBrush="{DynamicResource AccentRedBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,14"
                            Visibility="{Binding GeneralError, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding GeneralError}" FontSize="12"
                                   Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" />
                    </Border>

                    <!-- ── SECCIÓN 1: DATOS DEL TRADE ── -->
                    <TextBlock Text="DATOS DEL TRADE" Style="{StaticResource SectionLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_Account}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_Strategy}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Strategies}"
                                      SelectedItem="{Binding SelectedStrategy}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_Symbol}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Symbols}"
                                      Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_Direction}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Directions}"
                                      SelectedItem="{Binding SelectedDirection}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                    </Grid>

                    <!-- Fechas -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_EntryDate}" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding EntryDate}" Style="{DynamicResource FormDatePicker}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_EntryTime}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding EntryTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="HH:mm" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_ExitDate}" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding ExitDate}" Style="{DynamicResource FormDatePicker}" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_ExitTime}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ExitTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="HH:mm" />
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,16" />

                    <!-- ── SECCIÓN 2: EJECUCIÓN ── -->
                    <TextBlock Text="EJECUCIÓN" Style="{StaticResource SectionLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_EntryPrice}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding EntryPriceText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_ExitPrice}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ExitPriceText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_StopLoss}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding StopLossText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_TakeProfit}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding TakeProfitText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.00000" />
                        </StackPanel>
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="{loc:Tr Journal_PositionSize}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding PositionSizeText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="0.01" />
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,16" />

                    <!-- ── SECCIÓN 3: RESULTADO ── -->
                    <TextBlock Text="RESULTADO" Style="{StaticResource SectionLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" MaxWidth="150" />
                        </Grid.ColumnDefinitions>

                        <!-- Resultado (auto) -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="{loc:Tr Journal_Result}"
                                           Style="{StaticResource FieldLabel}" Margin="0" />
                                <Border Background="#0F00D4FF" CornerRadius="3"
                                        Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="auto" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource CyanGlowBrush}" />
                                </Border>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding Results}"
                                      SelectedItem="{Binding SelectedResult}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_ProfitLoss}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ProfitLossText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="+120.50" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_RiskAmount}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding RiskAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="100.00" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{loc:Tr Journal_RR}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding RrText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}" Tag="2.5" />
                        </StackPanel>
                        <!-- Calificación -->
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="{loc:Tr Journal_Rating}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding RatingOptions}"
                                      SelectedItem="{Binding SelectedRating}"
                                      Style="{DynamicResource FormComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text"       Value="— Sin calificar —" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="8"><Setter Property="Foreground" Value="#00E676" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="9"><Setter Property="Foreground" Value="#00E676" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="10"><Setter Property="Foreground" Value="#00E676" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="1"><Setter Property="Foreground" Value="#FF5555" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="2"><Setter Property="Foreground" Value="#FF5555" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="3"><Setter Property="Foreground" Value="#FF5555" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="4"><Setter Property="Foreground" Value="#FF5555" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,16" />

                    <!-- ── SECCIÓN 4: CONTEXTO ── -->
                    <TextBlock Text="CONTEXTO DE MERCADO" Style="{StaticResource SectionLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="300" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" MaxWidth="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Tr Journal_Session}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Sessions}"
                                      SelectedItem="{Binding SelectedSession}"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_Timeframe}" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Timeframes}"
                                      Text="{Binding SelectedTimeframe, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Style="{DynamicResource FormComboBox}" />
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,16" />

                    <!-- ── SECCIÓN 5: PSICOLOGÍA, GRÁFICO Y NOTAS ── -->
                    <TextBlock Text="PSICOLOGÍA, GRÁFICO Y NOTAS" Style="{StaticResource SectionLabel}" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="{loc:Tr Journal_EmotionalState}" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding EmotionalStates}"
                                          SelectedItem="{Binding SelectedEmotionalState}"
                                          Style="{DynamicResource FormComboBox}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{loc:Tr Journal_MistakeType}" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding MistakeTypes}"
                                          SelectedItem="{Binding SelectedMistakeType}"
                                          Style="{DynamicResource FormComboBox}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Tr Journal_ScreenshotUrl}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ScreenshotUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     Tag="https://www.tradingview.com/chart/..." />
                            <Border Margin="0,8,0,0"
                                    Visibility="{Binding ScreenshotUrl, Converter={StaticResource StringToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{DynamicResource PrimaryButton}"
                                            Height="32" Padding="12,0" FontSize="12"
                                            Command="{Binding OpenScreenshotCommand}"
                                            CommandParameter="{Binding ScreenshotUrl}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center" />
                                            <TextBlock Text="Abrir gráfico" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SurfaceElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="10,7">
                                        <TextBlock Text="{Binding ScreenshotUrl}"
                                                   FontSize="11" Foreground="{DynamicResource CyanGlowBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding ScreenshotUrl}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{loc:Tr Journal_Notes}" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource FormTextBox}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Height="100" VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Tag="Observaciones, aprendizajes, contexto del mercado…" />
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer con botones ── -->
            <Border Grid.Row="3"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Indicador de carga -->
                    <TextBlock Grid.Column="0"
                               Text="Guardando…"
                               FontSize="12" FontStyle="Italic"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />

                    <!-- Cancelar -->
                    <Button Grid.Column="1"
                            Content="{loc:Tr Journal_Cancel}"
                            Style="{DynamicResource GhostButton}"
                            Command="{Binding CancelCommand}"
                            Height="40" Padding="20,0" FontSize="13" />

                    <!-- Guardar -->
                    <Button Grid.Column="3"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Height="40" Padding="24,0" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Content" Value="{loc:Tr Journal_Save}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Content" Value="{loc:Tr Journal_Saving}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Command>
                            <Binding Path="SaveCommand" />
                        </Button.Command>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
