<Window x:Class="Application.WPF.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Application.WPF.ViewModels.Main;assembly=Application.WPF.ViewModels"
        xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
        xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{loc:Tr App_Title}"
        MinHeight="640" MinWidth="960"
        Height="760" Width="1360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:ViewModelToViewConverter x:Key="ViewModelToView" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3" />
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- Top cyan line -->
        <Border Grid.Row="0" Background="{DynamicResource CyanGlowBrush}" />

        <!-- Navbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="6" Height="24" CornerRadius="3"
                            Background="{DynamicResource CyanGlowBrush}"
                            Margin="0,0,12,0" />
                    <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="TRADING" Foreground="#00D4FF" />
                        <Run Text="JOURNAL" Foreground="{DynamicResource TextPrimaryBrush}" />
                    </TextBlock>
                </StackPanel>

                <!-- Nav links -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="{loc:Tr Nav_Dashboard}"
                            Style="{DynamicResource GhostButton}"
                            Foreground="{DynamicResource PrimaryBrush}" />
                    <Button Content="{loc:Tr Nav_Journal}"   Style="{DynamicResource GhostButton}" />
                    <Button Content="{loc:Tr Nav_Analytics}" Style="{DynamicResource GhostButton}" />
                    <Button Content="{loc:Tr Nav_Settings}"  Style="{DynamicResource GhostButton}" />
                </StackPanel>

                <!-- Right side: Language selector + LIVE badge -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,0,0">

                    <!-- Language selector -->
                    <Border CornerRadius="4"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,10,0"
                            Padding="2,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🌐"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="6,0,4,0" />
                            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      DisplayMemberPath="DisplayName"
                                      MinWidth="148"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontSize="12"
                                      VerticalAlignment="Center">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="Padding"    Value="10,6" />
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- LIVE badge -->
                    <Border CornerRadius="4"
                            Background="#33FF3333"
                            BorderBrush="#FF3333"
                            BorderThickness="1"
                            Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#FF3333"
                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF3333" BlurRadius="6" ShadowDepth="0" Opacity="1" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="{loc:Tr Nav_Live}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#FF3333"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <ContentControl Grid.Row="2"
                        Content="{Binding CurrentView, Converter={StaticResource ViewModelToView}}" />

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Tr StatusBar_Ready}"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#00E676" Margin="0,0,5,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00E676" BlurRadius="4" ShadowDepth="0" Opacity="0.8" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="{loc:Tr App_Version}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
