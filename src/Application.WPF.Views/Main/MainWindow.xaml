<Window x:Class="Application.WPF.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Application.WPF.ViewModels.Main;assembly=Application.WPF.ViewModels"
        xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
        xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{loc:Tr App_Title}"
        MinHeight="640" MinWidth="960"
        Height="760" Width="1360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:ViewModelToViewConverter   x:Key="ViewModelToView" />
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility" />

        <!-- ToggleButton con aspecto idéntico a GhostButton -->
        <Style x:Key="GhostToggleButton" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Padding"         Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0FFFFFFF" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15FFFFFF" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3" />
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- Top cyan line -->
        <Border Grid.Row="0" Background="{DynamicResource CyanGlowBrush}"
                Visibility="{Binding ShowShell, Converter={StaticResource BoolToVisibility}}" />

        <!-- Navbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowShell, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="6" Height="24" CornerRadius="3"
                            Background="{DynamicResource CyanGlowBrush}"
                            Margin="0,0,12,0" />
                    <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="TRADING" Foreground="#00D4FF" />
                        <Run Text="JOURNAL" Foreground="{DynamicResource TextPrimaryBrush}" />
                    </TextBlock>
                </StackPanel>

                <!-- Nav links -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Dashboard -->
                    <Button Content="{loc:Tr Nav_Dashboard}"
                            Style="{DynamicResource GhostButton}"
                            Foreground="{DynamicResource PrimaryBrush}"
                            Command="{Binding GoToDashboardCommand}" />

                    <Button Content="{loc:Tr Nav_Journal}"   Style="{DynamicResource GhostButton}" />
                    <Button Content="{loc:Tr Nav_Analytics}" Style="{DynamicResource GhostButton}" />

                    <Button Content="{loc:Tr Nav_Account}"
                            Style="{DynamicResource GhostButton}"
                            Command="{Binding GoToTradingAccountCommand}" />

                    <Button Content="{loc:Tr Nav_Strategies}"
                            Style="{DynamicResource GhostButton}"
                            Command="{Binding GoToStrategiesCommand}" />

                    <Button Content="{loc:Tr Nav_Settings}" Style="{DynamicResource GhostButton}" />

                </StackPanel>

                <!-- Right side: Language selector + LIVE badge -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,0,0">

                    <!-- Language selector -->
                    <Border CornerRadius="4"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,10,0"
                            Padding="2,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🌐"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="6,0,4,0" />
                            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      DisplayMemberPath="DisplayName"
                                      MinWidth="148"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontSize="12"
                                      VerticalAlignment="Center">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="Padding"    Value="10,6" />
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Usuario autenticado — chip con menú desplegable -->
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center"
                                Margin="0,0,10,0"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">

                        <ToggleButton x:Name="UserMenuToggle"
                                      Style="{StaticResource GhostToggleButton}"
                                      Padding="8,5">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="24" Height="24" CornerRadius="12"
                                        Background="{DynamicResource CyanGlowBrush}"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="{Binding CurrentUsername[0], FallbackValue=?}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#0A0E1A"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding CurrentUsername}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBlock Text="▾" FontSize="9"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>

                        <Popup IsOpen="{Binding IsChecked, ElementName=UserMenuToggle}"
                               PlacementTarget="{Binding ElementName=UserMenuToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MinWidth="200"
                                    Margin="0,4,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="16"
                                                      ShadowDepth="4" Opacity="0.5" />
                                </Border.Effect>
                                <StackPanel Margin="4">

                                    <!-- Cabecera con nombre completo -->
                                    <StackPanel Margin="12,10,12,8">
                                        <TextBlock Text="{Binding CurrentUsername}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{loc:Tr Nav_MyAccount}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}"
                                               Margin="8,0,8,4" />

                                    <!-- Perfil de usuario -->
                                    <Button Style="{DynamicResource GhostButton}"
                                            HorizontalContentAlignment="Left"
                                            HorizontalAlignment="Stretch"
                                            Padding="12,10"
                                            Command="{Binding GoToSettingsCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👤" FontSize="13"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" />
                                            <StackPanel>
                                                <TextBlock Text="{loc:Tr Nav_Profile}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="{loc:Tr Nav_ProfileDesc}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>

                                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}"
                                               Margin="8,4" />

                                    <!-- Cerrar sesión -->
                                    <Button Style="{DynamicResource GhostButton}"
                                            HorizontalContentAlignment="Left"
                                            HorizontalAlignment="Stretch"
                                            Padding="12,10"
                                            Command="{Binding LogoutCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⏻" FontSize="13"
                                                       Foreground="{DynamicResource AccentRedBrush}"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{loc:Tr Nav_Logout}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentRedBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>

                    <!-- LIVE badge -->
                    <Border CornerRadius="4"
                            Background="#33FF3333"
                            BorderBrush="#FF3333"
                            BorderThickness="1"
                            Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#FF3333"
                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF3333" BlurRadius="6" ShadowDepth="0" Opacity="1" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="{loc:Tr Nav_Live}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#FF3333"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <ContentControl Grid.Row="2"
                        Content="{Binding CurrentView, Converter={StaticResource ViewModelToView}}" />

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding ShowShell, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Tr StatusBar_Ready}"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#00E676" Margin="0,0,5,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00E676" BlurRadius="4" ShadowDepth="0" Opacity="0.8" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="{loc:Tr App_Version}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
