<UserControl x:Class="Application.WPF.Views.Evaluator.TradingEvaluatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Application.WPF.ViewModels.Evaluator;assembly=Application.WPF.ViewModels"
             xmlns:strategies="clr-namespace:Application.WPF.Views.Strategies"
             xmlns:common="clr-namespace:Application.WPF.Views.Common"
             xmlns:converters="clr-namespace:Application.WPF.Views.Converters"
             xmlns:loc="clr-namespace:Application.WPF.Views.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TradingEvaluatorViewModel}"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />

        <!-- Checkbox personalizado para el checklist de reglas — consistente con el tema oscuro -->
        <Style x:Key="RuleCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Box" Width="24" Height="24" CornerRadius="6"
                                Background="#0A0E1A"
                                BorderBrush="#333355" BorderThickness="1.5">
                            <TextBlock x:Name="Check" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#0A0E1A"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box"   Property="Background"  Value="#00D4FF" />
                                <Setter TargetName="Box"   Property="BorderBrush" Value="#00D4FF" />
                                <Setter TargetName="Check" Property="Opacity"     Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#00D4FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Placeholder reutilizable cuando no hay estrategia seleccionada -->
        <Style x:Key="EmptyCard" TargetType="Border">
            <Setter Property="Background" Value="#0F1117" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <!-- Encabezado de tarjeta — consistente entre Reglas y Confluencias -->
        <Style x:Key="CardHeader" TargetType="Border">
            <Setter Property="Background" Value="#161B27" />
            <Setter Property="CornerRadius" Value="8,8,0,0" />
            <Setter Property="Padding" Value="16,12" />
        </Style>
        <Style x:Key="CardHeaderLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#00D4FF" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,16,24,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="400" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Border Width="4" Height="20" CornerRadius="2"
                        Background="{DynamicResource CyanGlowBrush}" Margin="0,0,10,0" />
                <TextBlock Text="{loc:Tr Evaluator_Title}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{loc:Tr Evaluator_Subtitle}"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Cuerpo: 2 columnas que ocupan todo el alto disponible -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ Columna izquierda: Selector + Gráfico ═══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Selector de estrategia + botón de calculadora -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{loc:Tr Evaluator_SelectStrategy}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding Strategies}"
                                  SelectedItem="{Binding SelectedStrategy}"
                                  DisplayMemberPath="Title"
                                  Style="{DynamicResource FormComboBox}" />
                    </StackPanel>

                    <!-- Botón para abrir la calculadora de lotaje en ventana flotante -->
                    <Button Grid.Column="2" Style="{DynamicResource SecondaryButton}"
                            VerticalAlignment="Bottom" Height="36" Padding="14,0"
                            Click="OnOpenLotCalculator">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Tr Evaluator_OpenLotCalculator}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Gráfico de la estrategia -->
                <Border Grid.Row="1" Style="{StaticResource EmptyCard}" ClipToBounds="True"
                        Visibility="{Binding HasNoStrategySelected, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Tr Evaluator_NoStrategySelected}"
                               FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <Border Grid.Row="1" Style="{StaticResource EmptyCard}" ClipToBounds="True"
                        Visibility="{Binding HasStrategySelected, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Título de la estrategia (descripción oculta para priorizar el gráfico) -->
                        <Border Grid.Row="0" Style="{StaticResource CardHeader}" Padding="16,8">
                            <TextBlock Text="{Binding SelectedStrategy.Title}"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>

                        <!-- Imagen (zoom con rueda, pan con clic+arrastre) -->
                        <Grid Grid.Row="1" ClipToBounds="True">
                            <common:ZoomableImage Source="{Binding ChartImage}"
                                                  Visibility="{Binding HasChartImage, Converter={StaticResource BoolToVisibility}}" />

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding HasNoChartImage, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,10" />
                                <TextBlock Text="{loc:Tr Evaluator_NoChart}"
                                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ Columna derecha: Reglas (arriba) y Calificador de confluencias (abajo) ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" MinHeight="180" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="1.4*" MinHeight="220" />
                </Grid.RowDefinitions>

                <!-- Checklist de reglas — todas deben cumplirse para que el trade sea válido -->
                <Border Grid.Row="0" Style="{StaticResource EmptyCard}"
                        Visibility="{Binding HasNoStrategySelected, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Tr Evaluator_NoStrategySelected}"
                               FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" />
                </Border>

                <Border Grid.Row="0" Style="{StaticResource EmptyCard}"
                        Visibility="{Binding HasStrategySelected, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Encabezado -->
                        <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" Height="14" CornerRadius="1.5"
                                        Background="#00D4FF" Margin="0,0,8,0" />
                                <TextBlock Text="{loc:Tr Evaluator_RulesTitle}" Style="{StaticResource CardHeaderLabel}" />
                            </StackPanel>
                        </Border>

                        <!-- Sin reglas -->
                        <TextBlock Grid.Row="1" Text="{loc:Tr Evaluator_RulesNone}"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" Margin="14"
                                   Visibility="{Binding HasNoRules, Converter={StaticResource BoolToVisibility}}" />

                        <!-- Lista de reglas: dos columnas para aprovechar el ancho -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,10">
                            <ItemsControl ItemsSource="{Binding RuleChecklist}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#161B27" CornerRadius="8"
                                                Margin="0,0,8,8" Padding="12,10"
                                                Cursor="Hand" MouseLeftButtonUp="OnRuleCardClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="22" Height="22" CornerRadius="11"
                                                        BorderBrush="#00D4FF" BorderThickness="1"
                                                        Margin="0,0,10,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#00D4FF" Opacity="0.1" />
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding DisplayIndex}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#00D4FF"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Description}"
                                                           FontSize="12" Foreground="White"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />

                                                <CheckBox Grid.Column="2"
                                                          IsChecked="{Binding IsChecked}"
                                                          Style="{StaticResource RuleCheckBox}"
                                                          IsHitTestVisible="False"
                                                          Margin="10,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Estado de validez -->
                        <Border Grid.Row="2" CornerRadius="0,0,8,8" Padding="16,12"
                                Visibility="{Binding HasRules, Converter={StaticResource BoolToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1AFF4444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValidSetup}" Value="True">
                                            <Setter Property="Background" Value="#1A00E676" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{loc:Tr Evaluator_RulesInvalid}" />
                                            <Setter Property="Foreground" Value="#FF5555" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsValidSetup}" Value="True">
                                                    <Setter Property="Text" Value="{loc:Tr Evaluator_RulesValid}" />
                                                    <Setter Property="Foreground" Value="#00E676" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding RulesProgressDisplay}"
                                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Calificador de confluencias (panel embebido) -->
                <Border Grid.Row="2" Style="{StaticResource EmptyCard}"
                        Visibility="{Binding HasNoStrategySelected, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Tr Evaluator_NoStrategySelected}"
                               FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <strategies:StrategyRaterPanel Grid.Row="2"
                                                DataContext="{Binding Rater}"
                                                Visibility="{Binding HasStrategySelected, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
